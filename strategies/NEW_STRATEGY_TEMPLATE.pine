//@version=5
strategy("SSL多时间框架策略", overlay=true, max_lines_count=500, max_labels_count=500, default_qty_type=strategy.percent_of_equity, default_qty_value=100)


// 1. 通过验证，发现5分钟与ssl斜率关系不大，因为斜率不影响到价格
// 


// ==================== 输入参数 ====================

// SSL参数
ssl_period = input.int(200, "SSL周期", minval=1, group="SSL设置")
ssl_wma_length = input.int(200, "SSL WMA长度", minval=1, group="SSL设置")
show_ssl = input.bool(true, "显示SSL通道", group="SSL设置")

// 策略参数
lookback_bars = input.int(3, "回看K线数量", minval=1, maxval=10, group="策略设置")
risk_reward_ratio = input.float(1.0, "风险回报比", minval=1.0, maxval=10.0, step=0.1, group="策略设置")
atr_length = input.int(14, "ATR周期", minval=1, group="策略设置")
initial_position_usd = input.float(100.0, "初始仓位(美元)", minval=1.0, step=1.0, group="策略设置")

// 注意：初始资金在TradingView的Strategy Tester设置中配置，不能在代码中直接设置
vwap_block_bars = input.int(30, "VWAP阻塞K线数", minval=1, maxval=100, group="策略设置", tooltip="连续多少根K线VWAP在SSL通道内时禁止开仓")

// 风控设置
enable_risk_control = input.bool(false, "开启风控模式", group="风控设置")
max_risk_percent = input.float(1.0, "风控最大比例(%)", minval=0.1, maxval=10.0, step=0.1, group="风控设置")





///////////////vwap/////////////////////////////////////////////////////////////////////////////////////////////////////////////////
// ─── 输入 ───
vwap_anchorMode  = input.string("Daily", "Anchor Mode", options=["Daily", "Weekly", "Monthly", "Custom"])
vwap_startHour   = input.int(8, "Custom Anchor Hour", minval=0, maxval=23)
vwap_startMinute = input.int(0, "Custom Anchor Minute", minval=0, maxval=59)

vwap_mult1 = input.float(1.0, "Band Multiplier 1", step=0.1)
vwap_mult2 = input.float(2.0, "Band Multiplier 2", step=0.1)

vwap_showVwap = input.bool(true, "Show VWAP Indicator")
show_vwap_upper1 = input.bool(false, "Show vwap_upper1")
show_vwap_upper2 = input.bool(false, "Show vwap_upper2")

// ─── 计算 Anchor 时间 ───
vwap_customAnchor = timestamp("GMT+0", year, month, dayofmonth, vwap_startHour, vwap_startMinute)

// 每个周期的 bar 是否为锚定点
vwap_isNewDay   = ta.change(time("D"))
vwap_isNewWeek  = ta.change(time("W"))
vwap_isNewMonth = ta.change(time("M"))

vwap_isAnchor = switch vwap_anchorMode
    "Daily"   => vwap_isNewDay
    "Weekly"  => vwap_isNewWeek
    "Monthly" => vwap_isNewMonth
    "Custom"  => time >= vwap_customAnchor and ta.change(time("D"))  // 每天一次自定义锚点
    => false

// ─── 累积变量 ───
var float vwap_cumPV = 0.0
var float vwap_cumVol = 0.0
var float vwap_cumSQ = 0.0
var float vwap_val = na
var float vwap_upper1 = na
var float vwap_lower1 = na
var float vwap_upper2 = na
var float vwap_lower2 = na

// ─── 每次新锚点重置 ───
if vwap_isAnchor
    vwap_cumPV := 0
    vwap_cumVol := 0
    vwap_cumSQ := 0

// ─── 计算 Anchored VWAP ───
vwap_typical = hlc3
vwap_cumPV += vwap_typical * volume
vwap_cumVol += volume
vwap_cumSQ += vwap_typical * vwap_typical * volume

vwap_val := vwap_cumVol > 0 ? vwap_cumPV / vwap_cumVol : na

// 标准差
vwap_mean_sq = vwap_cumVol > 0 ? vwap_cumSQ / vwap_cumVol : na
vwap_variance = na(vwap_mean_sq) ? na : math.max(vwap_mean_sq - vwap_val * vwap_val, 0)
vwap_stdev = math.sqrt(vwap_variance)

vwap_upper1 := na(vwap_val) ? na : vwap_val + vwap_mult1 * vwap_stdev
vwap_lower1 := na(vwap_val) ? na : vwap_val - vwap_mult1 * vwap_stdev
vwap_upper2 := na(vwap_val) ? na : vwap_val + vwap_mult2 * vwap_stdev
vwap_lower2 := na(vwap_val) ? na : vwap_val - vwap_mult2 * vwap_stdev

// ─── 绘图 ───
plot(vwap_showVwap ? vwap_val : na, "Anchored VWAP", color=color.white, linewidth=2)
plot(vwap_showVwap and show_vwap_upper1 ? vwap_upper1 : na, "Upper Band 1", color=color.new(color.blue, 0), linewidth=1)
plot(vwap_showVwap and show_vwap_upper1 ? vwap_lower1 : na, "Lower Band 1", color=color.new(color.blue, 0), linewidth=1)
plot(vwap_showVwap and show_vwap_upper2 ? vwap_upper2 : na, "Upper Band 2", color=color.new(color.blue, 50), linewidth=1)
plot(vwap_showVwap and show_vwap_upper2 ? vwap_lower2 : na, "Lower Band 2", color=color.new(color.blue, 50), linewidth=1)


showEma = input.bool(false, 'show EMA')

// --- Inputs ---
len1  = input.int(14,  minval=1, title="EMA 1")
len2  = input.int(30,  minval=1, title="EMA 2")
len3  = input.int(144, minval=1, title="EMA 3")
len4  = input.int(169, minval=1, title="EMA 4")

mult_ema_src1  = input.source(close, title="EMA 1 Source")
mult_ema_src2  = input.source(close, title="EMA 2 Source")
mult_ema_src3  = input.source(close, title="EMA 3 Source")
mult_ema_src4  = input.source(close, title="EMA 4 Source")

// --- Calculations ---
ema1 = ta.ema(mult_ema_src1,  len1)
ema2 = ta.ema(mult_ema_src2,  len2)
ema3 = ta.ema(mult_ema_src3,  len3)
ema4 = ta.ema(mult_ema_src4,  len4)

// --- Plots ---
// plot(showEma ? ema1 : na, color=color.green,  linewidth=1, title="EMA 1")
// plot(showEma ? ema2 : na, color=color.blue,   linewidth=1, title="EMA 2")
plot(showEma ? ema3 : na, color=color.green, linewidth=2, title="EMA 3")
plot(showEma ? ema4 : na, color=color.rgb(255, 170, 59), linewidth=2, title="EMA 4")






//////////////////mybolling////////////////////////////////////////////////////////////////////////////


showMyboll = input.bool(false, 'mybolling')

myboll_length = input.int(20, minval=1)
myboll_type = input.string("SMA", "myboll_basis MA Type", options = ["SMA", "EMA", "SMMA (RMA)", "WMA", "VWMA"])
myboll_src = input(close, title="Source")
myboll_mult = input.float(2.0, minval=0.001, maxval=50, title="Stdmyboll_dev")

ma(source, myboll_length, _type) =>
    switch _type
        "SMA" => ta.sma(source, myboll_length)
        "EMA" => ta.ema(source, myboll_length)
        "SMMA (RMA)" => ta.rma(source, myboll_length)
        "WMA" => ta.wma(source, myboll_length)
        "VWMA" => ta.vwma(source, myboll_length)

myboll_basis = ma(myboll_src, myboll_length, myboll_type)
myboll_dev = myboll_mult * ta.dev(myboll_src, myboll_length)
myboll_upper = myboll_basis + myboll_dev
myboll_lower = myboll_basis - myboll_dev
myboll_offset = input.int(0, "myboll_offset", minval = -500, maxval = 500, display = display.data_window)
plot(showMyboll ? myboll_basis : na, "myboll_basis", color=#089981, offset = myboll_offset)
myboll_p1 = plot(showMyboll ? myboll_upper : na, "myboll_upper", color=#089981, offset = myboll_offset)
myboll_p2 = plot(showMyboll ? myboll_lower : na, "myboll_lower", color=#089981, offset = myboll_offset)
// fill(myboll_p1, myboll_p2, title = "Background", color=color.rgb(33, 150, 243, 95))


myboll_basis2 = ma(myboll_src, myboll_length * 3, myboll_type)
myboll_dev2 = myboll_mult * ta.dev(myboll_src, myboll_length * 3)
myboll_upper2 = myboll_basis2 + myboll_dev2
myboll_lower2 = myboll_basis2 - myboll_dev2
myboll_offset2 = input.int(0, "myboll_offset2", minval = -500, maxval = 500, display = display.data_window)
plot(showMyboll ? myboll_basis2 : na, "myboll_basis2", color=#2962FF, offset = myboll_offset2)
myboll_p2_1 = plot(showMyboll ? myboll_upper2 : na, "myboll_upper2", color=#2962FF, offset = myboll_offset2)
myboll_p2_2 = plot(showMyboll ? myboll_lower2 : na, "myboll_lower2", color=#2962FF, offset = myboll_offset2)



myboll_basis3 = ma(myboll_src, myboll_length * 12, myboll_type)
myboll_dev3 = myboll_mult * ta.dev(myboll_src, myboll_length * 12)
myboll_upper3 = myboll_basis3 + myboll_dev3
myboll_lower3 = myboll_basis3 - myboll_dev3
myboll_offset3 = input.int(0, "myboll_offset3", minval = -500, maxval = 500, display = display.data_window)
plot(showMyboll ? myboll_basis3 : na, "myboll_basis3", color=#F23645, offset = myboll_offset3)
myboll_p3_1 = plot(showMyboll ? myboll_upper3 : na, "myboll_upper3", color=#F23645, offset = myboll_offset3)
myboll_p3_2 = plot(showMyboll ? myboll_lower3 : na, "myboll_lower3", color=#F23645, offset = myboll_offset3)



// ==================== SSL指标函数 ====================

// SSL指标计算函数
ssl_calc(period, wma_len) =>
    smaHigh = ta.wma(high, wma_len)
    smaLow = ta.wma(low, wma_len)
    
    var float Hlv = na
    Hlv := close > smaHigh ? 1 : close < smaLow ? -1 : Hlv[1]
    
    sslDown = Hlv < 0 ? smaHigh : smaLow
    sslUp = Hlv < 0 ? smaLow : smaHigh
    
    [sslUp, sslDown, Hlv]

// ==================== 多时间框架SSL计算 ====================

// 当前时间框架SSL（5分钟）
[current_ssl_up, current_ssl_down, current_hlv] = ssl_calc(ssl_period, ssl_wma_length)

// 15分钟时间框架SSL（辅助时间框架）
[ssl_up_15m, ssl_down_15m, hlv_15m] = request.security(syminfo.tickerid, "15", ssl_calc(ssl_period, ssl_wma_length))

// ==================== ATR计算 ====================

// 计算ATR
current_atr = ta.atr(atr_length)

// ==================== 止损位计算 ====================

// 初始止损位
initial_long_stop = current_ssl_down - current_atr
initial_short_stop = current_ssl_up + current_atr

// 止损止盈位变量
var float long_stop_loss_level = na
var float short_stop_loss_level = na
var float long_entry_price = na
var float short_entry_price = na
var int long_entry_bar = 0
var int short_entry_bar = 0
var bool long_trailing_activated = false
var bool short_trailing_activated = false

// 保存初始止损位用于计算固定止盈位
var float long_initial_stop = na
var float short_initial_stop = na

// ==================== 绘制SSL通道 ====================

// 绘制当前时间框架SSL
p1 = plot(show_ssl ? current_ssl_down : na, linewidth=1, color=color.new(color.green, 80), title="SSL下轨")
p2 = plot(show_ssl ? current_ssl_up : na, linewidth=1, color=color.new(color.green, 80), title="SSL上轨")

// 填充SSL区域
fill(p1, p2, color = current_hlv > 0 ? color.new(color.green, 80) : color.new(color.red, 80), title="SSL填充")

// 绘制止损线
plot(strategy.position_size > 0 ? long_stop_loss_level : na, "多单止损线", color=color.red, linewidth=2, style=plot.style_linebr)
plot(strategy.position_size < 0 ? short_stop_loss_level : na, "空单止损线", color=color.red, linewidth=2, style=plot.style_linebr)

// 绘制止盈线（使用初始止损位计算固定止盈位）
long_take_profit_level = not na(long_entry_price) and not na(long_initial_stop) ? long_entry_price + (long_entry_price - long_initial_stop) * risk_reward_ratio : na
short_take_profit_level = not na(short_entry_price) and not na(short_initial_stop) ? short_entry_price - (short_initial_stop - short_entry_price) * risk_reward_ratio : na
plot(strategy.position_size > 0 ? long_take_profit_level : na, "多单止盈线", color=color.green, linewidth=2, style=plot.style_linebr)
plot(strategy.position_size < 0 ? short_take_profit_level : na, "空单止盈线", color=color.green, linewidth=2, style=plot.style_linebr)

// ==================== SSL下沿斜率计算 ====================

// 计算SSL下沿斜率：(当前SSL下沿 - 10根K线前的SSL下沿) / 10
ssl_down_slope = (current_ssl_down - current_ssl_down[10]) / 10

// ==================== VWAP在SSL通道内判断 ====================

// 判断当前VWAP是否在SSL通道内
vwap_in_ssl_channel = not na(vwap_val) and not na(current_ssl_down) and not na(current_ssl_up) and vwap_val >= current_ssl_down and vwap_val <= current_ssl_up

// 检查连续N根K线VWAP都在SSL通道内
vwap_in_channel_count = 0
for i = 0 to vwap_block_bars - 1
    vwap_i = vwap_val[i]
    ssl_down_i = current_ssl_down[i]
    ssl_up_i = current_ssl_up[i]
    if not na(vwap_i) and not na(ssl_down_i) and not na(ssl_up_i) and vwap_i >= ssl_down_i and vwap_i <= ssl_up_i
        vwap_in_channel_count += 1

// 如果连续N根K线的VWAP都在SSL通道内，禁止开仓
vwap_blocked = vwap_in_channel_count >= vwap_block_bars

// ==================== 开仓条件判断 ====================

// 多单开仓条件
long_condition = 
     close > current_ssl_up and  // 当前K线收盘价大于SSL上沿
     low <= current_ssl_up and  // 当前K线最低价小于等于SSL上沿
     ((close[2] >= close[3] and close[1] >= close[2] and close >= close[1]) or  // 最近三根K线都是上升K线
     (ta.lowest(math.min(open, close), 5) > current_ssl_down)) and  // 最近5根K线实体最小值大于SSL下沿
           close > vwap_val and  // 当前K线收盘价大于VWAP值
      not vwap_blocked  // VWAP未在SSL通道内超过设定K线数
    //  ssl_down_slope > 1 and  // SSL下沿不是太向下倾斜
    //  hlv_15m > 0  // 15分钟时间框架确认多头趋势

// 空单开仓条件
short_condition = false
    // close < current_ssl_down and  // 当前K线收盘价小于SSL下沿
    // high >= current_ssl_down and  // 当前K线最高价大于等于SSL下沿
    // ((close[2] <= close[3] and close[1] <= close[2] and close <= close[1]) or  // 最近三根K线都是下跌K线
    // (ta.highest(math.max(open, close), 5) < current_ssl_up)) and  // 最近5根K线实体最大值小于SSL上沿
    // close < vwap_val and  // 当前K线收盘价小于VWAP值
    // ssl_down_slope < 0.0005 and  // SSL下沿不是太向上倾斜
    // hlv_15m < 0  // 15分钟时间框架确认空头趋势

// ==================== 止损止盈管理 ====================

// 开仓时设置初始止损位
if long_condition and strategy.position_size == 0
    long_stop_loss_level := initial_long_stop
    long_initial_stop := initial_long_stop  // 保存初始止损位
    long_entry_bar := bar_index
    long_trailing_activated := false

if short_condition and strategy.position_size == 0
    short_stop_loss_level := initial_short_stop
    short_initial_stop := initial_short_stop  // 保存初始止损位
    short_entry_bar := bar_index
    short_trailing_activated := false

// 多单移动止损：5根K线后移动到SSL下沿
if strategy.position_size > 0 and not na(long_entry_bar) and (bar_index - long_entry_bar) >= 5
    if not long_trailing_activated
        long_stop_loss_level := current_ssl_down
        long_trailing_activated := true
    else
        // 如果已经激活移动止损，持续更新为当前SSL下沿
        long_stop_loss_level := current_ssl_down

// 空单移动止损：5根K线后移动到SSL上沿
if strategy.position_size < 0 and not na(short_entry_bar) and (bar_index - short_entry_bar) >= 5
    if not short_trailing_activated
        short_stop_loss_level := current_ssl_up
        short_trailing_activated := true
    else
        // 如果已经激活移动止损，持续更新为当前SSL上沿
        short_stop_loss_level := current_ssl_up


// ==================== 止损止盈条件 ====================

// 多单止损：价格收盘价小于止损位
long_stop_loss = close < long_stop_loss_level

// 多单止盈：引线穿过止盈位就算止盈
long_take_profit = high >= long_take_profit_level

// 空单止损：价格收盘价大于止损位
short_stop_loss = close > short_stop_loss_level

// 空单止盈：引线穿过止盈位就算止盈
short_take_profit = low <= short_take_profit_level

// ==================== 策略执行 ====================

// 风控函数：根据止损比例计算下单金额
// 目标：确保单次亏损金额不超过账户总额的1%
// 计算公式：单次亏损 = 止损百分比 × 下单金额
//         单次亏损 ≤ 账户价值 × 最大风险比例
//         因此：下单金额 = (账户价值 × 最大风险比例) / 止损百分比
calculate_position_size(entry_price, stop_loss_price) =>
    position_value = initial_position_usd  // 默认值
    
    if enable_risk_control
        // 计算止损百分比：|开仓价 - 止损价| / 开仓价
        stop_loss_percent = math.abs(entry_price - stop_loss_price) / entry_price
        
        // 获取当前账户总价值
        current_equity = strategy.equity
        
        // 如果账户价值小于100，按100计算
        base_capital = current_equity < 100 ? 100 : current_equity
        
        // 计算最大允许亏损金额 = 账户价值 × 最大风险比例（默认1%）
        max_loss_amount = base_capital * (max_risk_percent / 100)
        
        // 计算下单金额：单次亏损 ≤ 账户价值 × 1%
        // position_value × stop_loss_percent ≤ base_capital × max_risk_percent
        // position_value = (base_capital × max_risk_percent) / stop_loss_percent
        if stop_loss_percent > 0
            position_value := max_loss_amount / stop_loss_percent
            
            // 验证：单次亏损金额是否符合要求
            // actual_loss = position_value × stop_loss_percent ≈ max_loss_amount
            // actual_loss = base_capital × max_risk_percent
            
            // 确保下单金额至少为100美元（满足最小下单要求）
            position_value := math.max(position_value, 100)
    // 如果不开启风控模式，position_value 保持默认值 initial_position_usd
    
    position_value

// 开多单
if long_condition and strategy.position_size == 0
    // 根据风控模式计算下单金额
    position_value = calculate_position_size(close, initial_long_stop)
    position_qty = position_value / close
    strategy.entry("Long", strategy.long, qty=position_qty)
    long_entry_price := close

// 开空单
if short_condition and strategy.position_size == 0
    // 根据风控模式计算下单金额
    position_value = calculate_position_size(close, initial_short_stop)
    position_qty = position_value / close
    strategy.entry("Short", strategy.short, qty=position_qty)
    short_entry_price := close

// 多单出场
if strategy.position_size > 0
    if long_stop_loss
        strategy.close("Long", comment="多单止损")
        long_entry_price := na
        long_stop_loss_level := na
        long_initial_stop := na
        long_entry_bar := 0
        long_trailing_activated := false
    else if long_take_profit
        strategy.close("Long", comment="多单止盈")
        long_entry_price := na
        long_stop_loss_level := na
        long_initial_stop := na
        long_entry_bar := 0
        long_trailing_activated := false

// 空单出场
if strategy.position_size < 0
    if short_stop_loss
        strategy.close("Short", comment="空单止损")
        short_entry_price := na
        short_stop_loss_level := na
        short_initial_stop := na
        short_entry_bar := 0
        short_trailing_activated := false
    else if short_take_profit
        strategy.close("Short", comment="空单止盈")
        short_entry_price := na
        short_stop_loss_level := na
        short_initial_stop := na
        short_entry_bar := 0
        short_trailing_activated := false



