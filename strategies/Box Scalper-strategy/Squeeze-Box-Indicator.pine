//@version=5
indicator(title='Squeeze Box', shorttitle='Squeeze Box', overlay=true)

// ==========================================================================================
// 指标名称：Squeeze Box（箱体指标）
// 指标类型：主图叠加指标
// 指标描述：基于移动平均和标准差的通道指标，用于识别价格波动范围
// ==========================================================================================
//
// 指标说明：
// - Box上轨（BOX_bh）：基准线 + 标准差倍数
// - Box下轨（BOX_bl）：基准线 - 标准差倍数
// - 基准线（BOX_basis）：收盘价的简单移动平均
// - 颜色变化：
//   - 收盘价 > 基准线：绿色（看涨）
//   - 收盘价 < 基准线：红色（看跌）
// - 交易信号：
//   - 价格上穿Box下轨：潜在买入信号
//   - 价格下穿Box上轨：潜在卖出信号
//
// ==========================================================================================

BOX_Group       = 'Squeeze Box'
BOX_Period      = input.int(24,             title='Periods',        group=BOX_Group,        minval=1,       step=1)
BOX_Deviation   = input.int(3,              title='Deviation',      group=BOX_Group,        minval=1,       step=1)
BOX_Threshold   = input.int(50,             title='Threshold',      group=BOX_Group,        minval=1,       step=1)

// Box 计算
BOX_basis = ta.sma(close, BOX_Period)          // 基准线：收盘价的SMA
BOX_dev = BOX_Deviation * ta.stdev(close, BOX_Period)  // 标准差倍数
BOX_bh = BOX_basis + BOX_dev                    // Box上轨
BOX_bl = BOX_basis - BOX_dev                    // Box下轨

// 根据收盘价与基准线的关系设置颜色
boxcolor = close > BOX_basis ? color.green : color.red

// 绘制Box上轨和下轨
bhplot = plot(BOX_bh, color=color.new(boxcolor, 50), title="Box High Level")
blplot = plot(BOX_bl, color=color.new(boxcolor, 50), title="Box Low Level")

// 填充Box区域
fill(bhplot, blplot, color=color.new(boxcolor, 87), title="Box Fill")

