//@version=6
strategy("Multi-Timeframe FVG Strategy", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, margin_long=0, margin_short=0, max_boxes_count=500, max_lines_count=500, max_labels_count=500, max_bars_back=5000)

// ==========================================================================================
//
// 做多准备条件：
//     1. 切换到4h级别k线图，寻找到最近摆动高低点
//     2. 当前4h级别k线收盘时，回溯从当前k线到最近的摆动低点是否有向上的有效的4h级别的fvg形成
//     注意：4h级别k线图，最近摆动高低点包含一个fvg或者多个fvg，等待价格回测近的4h级别有效的fvg准备做多
//
// 准备做多满足以下任何一条失效：
//     1. 价格突破4h级别的摆动高点或者跌破4h级别摆动低点时做多条件失效
//     2. 或者价格在该摆动高低点区间内形成4h级别向下的fvg时做多条件失效
//
// 多单入场，满足所有准备做多的条件后，并且满足下面所有条件，下多单：
//     1. 切换到5m级别k线图，寻找到最近摆动高低点
//     2. 5分钟级别的最近的摆动低点小于当前4h级别找到的最近的fvg的上沿，并且当前收盘价大于当前4h级别fvg的下沿
//     3. 当前5分钟级别k线收盘时，回溯从当前k线到最近的摆动低点是否有向上的5分钟级别的fvg形成
//     4. 当前4h级别fvg仍然有效（有k线的low低于该4hfvg的下沿视为失效）
//
// 做多止损：
// 在当前5分钟级别的最近的摆动低点 - 最近21根k线的平均高度
//
// 做多止盈：
// 如果盈亏比超过1:3可立即平仓
//
// 移动止损(可以关闭该功能，默认开启)：
// 开启移动止损时，当盈亏比达到1:1、1:1.5、1:2、1:2.5时，都需要移动止损位置到5分钟级别最近摆动低点
//
// 做空准备条件：
//     1. 切换到4h级别k线图，寻找到最近摆动高低点
//     2. 当前4h级别k线收盘时，回溯从当前k线到最近的摆动高点是否有向下的有效的4h级别的fvg形成
//     注意：4h级别k线图，最近摆动高低点包含一个fvg或者多个fvg，等待价格回测近的4h级别有效的fvg准备做空
//
// 准备做空满足以下任何一条失效：
//     1. 价格突破4h级别的摆动低点或者突破4h级别摆动高点时做空条件失效
//     2. 或者价格在该摆动高低点区间内形成4h级别向上的fvg时做空条件失效
//
// 空单入场，满足所有准备做空的条件后，并且满足下面所有条件，下空单：
//     1. 切换到5m级别k线图，寻找到最近摆动高低点
//     2. 5分钟级别的最近的摆动高点大于当前4h级别找到的最近的fvg的下沿，并且当前收盘价小于当前4h级别fvg的上沿
//     3. 当前5分钟级别k线收盘时，回溯从当前k线到最近的摆动高点是否有向下的5分钟级别的fvg形成
//     4. 当前4h级别fvg仍然有效（有k线的high高于该4hfvg的上沿视为失效）
//
// 做空止损：
// 在当前5分钟级别的最近的摆动高点 + 最近21根k线的平均高度
//
// 做空止盈：
// 如果盈亏比超过1:3可立即平仓
//
// 移动止损(可以关闭该功能，默认开启)：
// 开启移动止损时，当盈亏比达到1:1、1:1.5、1:2、1:2.5时，都需要移动止损位置到5分钟级别最近摆动高点

// ==========================================================================================

// ==========================================================================================
//                                     HELPER FUNCTIONS
// ==========================================================================================

// Helper to delete a line and its associated label
delete_line_and_label(line l, label la) =>
    if not na(l)
        l.delete()
    if not na(la)
        la.delete()

// Helper to get line style from string input
getLineStyle(string lineOption) =>
    switch lineOption
        "┈" => line.style_dotted
        "╌" => line.style_dashed
        => line.style_solid

// ==========================================================================================
//                                     TYPE DEFINITIONS 
// ==========================================================================================

type Helper
    string name         = "Helper"

type FVG
    int tf_idx
    string tf
    string tf_label
    int tf_num
    box _box
    bool _type
    bool _isMitigated
    bool _isDrawn
    int left
    float top
    int right
    float bottom
    string extend=extend.none
    string border_style=line.style_solid
    int border_width=1
    color bgcolor
    color border_color
    string _text
    color text_color=color.white
    string text_halign=text.align_right
    string text_size

Helper helper = Helper.new()

method Validtimeframe(Helper helper, tf) =>
    helper.name := tf
    n1 = timeframe.in_seconds()
    n2 = timeframe.in_seconds(tf)
    n1 <= n2

// ==========================================================================================
//                                     USER INPUTS - FVG Settings
// ==========================================================================================

//--------------------------------- FVG Settings -------------------------------------------//
string fvg_group = "Fair Value Gap (FVG) - Multi-Timeframe"
bool isFvgToShow = input.bool(true, title='Display FVGs', group=fvg_group)
int fvgHistoryNbr = input.int(2000, 'Max Active FVGs per Timeframe', minval=1, maxval=5000, group=fvg_group, tooltip="Controls how many recent FVGs are tracked for each timeframe before the oldest ones are discarded.")
bool isMitigatedFvgToReduce = input.bool(false, title='Reduce Mitigated FVG Area', group=fvg_group)

// FVG Colors
color bullishFvgColor = input.color(color.new(color.green, 60), 'Bullish Color', group=fvg_group)
color bearishFvgColor = input.color(color.new(color.red, 60), 'Bearish Color', group=fvg_group)
color mitigatedFvgColor = input.color(color.new(#8c8c8c, 70), 'Mitigated Color', group=fvg_group)
color fvg_border_color_bull = input.color(color.new(color.green, 100), 'Bullish Border', group=fvg_group)
color fvg_border_color_bear = input.color(color.new(color.red, 100), 'Bearish Border', group=fvg_group)

label_size = input.string(size.normal, "Labels size", [size.tiny, size.small, size.normal, size.large, size.huge], group = fvg_group)
int fvgTFDistance = input.int(100, 'FVGs Timeframe Distance', minval=1, maxval=2000, group=fvg_group, tooltip="Controls how many candles on the right side between a timeframe FVG and one higher timeframe FVG.")

// Timeframe Inputs (up to 8)
// TF1设置为5M用于策略
bool tf1_show = input.bool(true, "TF1 (5M)", group = fvg_group)
string tf1 = input.timeframe("5", "", group=fvg_group)
string tf1_label = input.string("5M", "", group=fvg_group)

bool tf2_show = input.bool(false, "TF2", group = fvg_group)
string tf2 = input.timeframe("60", "", group=fvg_group)
string tf2_label = input.string("1H", "", group=fvg_group)

// TF3设置为4H用于策略
bool tf3_show = input.bool(true, "TF3 (4H)", group = fvg_group)
string tf3 = input.timeframe("240", "", group=fvg_group)
string tf3_label = input.string("4H", "", group=fvg_group)

bool tf4_show = input.bool(false, "TF4", group = fvg_group)
string tf4 = input.timeframe("D", "", group=fvg_group)
string tf4_label = input.string("1D", "", group=fvg_group)

bool tf5_show = input.bool(false, "TF5", group = fvg_group)
string tf5 = input.timeframe("W", "", group=fvg_group)
string tf5_label = input.string("1W", "", group=fvg_group)

bool tf6_show = input.bool(false, "TF6", group = fvg_group)
string tf6 = input.timeframe("1M", "", group=fvg_group)
string tf6_label = input.string("1M", "", group=fvg_group)

bool tf7_show = input.bool(false, "TF7", group = fvg_group)
string tf7 = input.timeframe("6M", "", group=fvg_group)
string tf7_label = input.string("6M", "", group=fvg_group)

bool tf8_show = input.bool(false, "TF8", group = fvg_group)
string tf8 = input.timeframe("12M", "", group=fvg_group)
string tf8_label = input.string("12M", "", group=fvg_group)

bool ltf_hide = input.bool(true, "Hide FVG's lowers than enabled timeframes?", group=fvg_group)
bool isAddBarIndex = input.bool(false, "Show FVG BarIndex?", group=fvg_group)

// ==========================================================================================
//                                 FVG GLOBAL VARIABLES
// ==========================================================================================

// Arrays variable
var FVG[] fvgBox1 = array.new<FVG>()
var FVG[] fvgBox2 = array.new<FVG>()
var FVG[] fvgBox3 = array.new<FVG>()
var FVG[] fvgBox4 = array.new<FVG>()
var FVG[] fvgBox5 = array.new<FVG>()
var FVG[] fvgBox6 = array.new<FVG>()
var FVG[] fvgBox7 = array.new<FVG>()
var FVG[] fvgBox8 = array.new<FVG>()

getIsTFShow(int tf_idx) =>
    switch tf_idx
        0 => tf1_show
        1 => tf2_show
        2 => tf3_show
        3 => tf4_show
        4 => tf5_show
        5 => tf6_show
        6 => tf7_show
        7 => tf8_show

getTFLabel(int tf_idx) =>
    switch tf_idx
        0 => tf1_label
        1 => tf2_label
        2 => tf3_label
        3 => tf4_label
        4 => tf5_label
        5 => tf6_label
        6 => tf7_label
        7 => tf8_label

// ==========================================================================================
//                                  FVG CORE FUNCTIONS
// ==========================================================================================

findFVGs (int tf_idx, string tf, string tf_label, int tf_num, FVG[] fvgBox) =>
    if (not ltf_hide or (ltf_hide and helper.Validtimeframe(tf)))
        [htf_high1, htf_low1, htf_high3, htf_low3, htf_time2] = request.security(syminfo.tickerid, tf, [high[1], low[1], high[3], low[3], time[2]], lookahead = barmerge.lookahead_on)
        isBullishFVG = htf_high3 < htf_low1
        isBearishFVG = htf_low3 > htf_high1

        // Bullish FVG process
        if isBullishFVG
            bool isDuplicated = false
            for [ie, fvgE] in fvgBox
                if (fvgE.top == htf_low1) and (fvgE.bottom == htf_high3)
                    isDuplicated := true

            if not isDuplicated
                FVG fvg1 = FVG.new(tf_idx, tf, tf_label, tf_num, na, true, false, false, left=bar_index - 2, top=htf_low1, right=0, bottom=htf_high3, extend = extend.none, border_style=line.style_solid, border_width=1, bgcolor=bullishFvgColor, border_color=color.new(color.green, 100), _text=tf_label, text_color=color.white, text_halign=text.align_right, text_size = label_size)
                fvgBox.push(fvg1)

                if (fvgBox.size() > fvgHistoryNbr + 1)
                    box b = fvgBox.get(0)._box
                    if not na(b)
                        box.delete(b)
                    fvgBox.remove(0)

        // Bearish FVG process
        if isBearishFVG
            bool isDuplicated2 = false
            for [ie, fvgE2] in fvgBox
                if (fvgE2.top == htf_low3) and (fvgE2.bottom == htf_high1)
                    isDuplicated2 := true

            if not isDuplicated2
                FVG fvg2 = FVG.new(tf_idx, tf, tf_label, tf_num, na, false, false, false, left=bar_index - 2, top=htf_low3, right=0, bottom=htf_high1, extend = extend.none, border_style=line.style_solid, border_width=1, bgcolor=bearishFvgColor, border_color=color.new(color.red, 100), _text=tf_label, text_color=color.white, text_halign=text.align_right, text_size = label_size)
                fvgBox.push(fvg2)

                if (fvgBox.size() > fvgHistoryNbr + 1)
                    box b2 = fvgBox.get(0)._box
                    if not na(b2)
                        box.delete(b2)
                    fvgBox.remove(0)
    0

// Draw FVG
FVGDraw () =>
    for i1 = 0 to 7
        if (getIsTFShow(i1))
            FVG[] fvgBox = switch (i1)
                0 => fvgBox1
                1 => fvgBox2
                2 => fvgBox3
                3 => fvgBox4
                4 => fvgBox5
                5 => fvgBox6
                6 => fvgBox7
                7 => fvgBox8
            // Loop into all values of the array
            for [index, value] in fvgBox
                if (not value._isDrawn)
                    value._isDrawn := true
                    // Processing FVG
                    value._box := box.new(left=value.left, top=value.top, right=bar_index + value.tf_num * fvgTFDistance, bottom=value.bottom, extend = value.extend, border_style=value.border_style, border_width=value.border_width, bgcolor=value.bgcolor, border_color=value.border_color, text=value._text + (isAddBarIndex ? str.tostring(bar_index) : ""), text_color=value.text_color, text_halign=value.text_halign, text_size = value.text_size)
                
                if (value._type)
                    // Check if FVG has been totally mitigated
                    if (low <= box.get_bottom(value._box))
                        box.delete(value._box)
                        fvgBox.remove(index)
                        0
                    else 
                        if (low < box.get_top(value._box))
                            box.set_bgcolor(value._box, mitigatedFvgColor)
                            
                            // Mitigated FVG Alert
                            if (not value._isMitigated)
                                alert("FVG has been mitigated", alert.freq_once_per_bar)
                                value._isMitigated := true

                            // Reduce FVG if needed
                            if (isMitigatedFvgToReduce)
                                box.set_text(value._box, value.tf_label + "X")
                                box.set_text_formatting(value._box, text.format_italic)
                                box.set_top(value._box, low)

                        box.set_right(value._box, bar_index + value.tf_num * fvgTFDistance)
                        0
                // Processing bearish FVG
                else
                    // Check if FVG has been mitigated
                    if (high >= box.get_top(value._box))
                        box.delete(value._box)
                        fvgBox.remove(index)
                        0
                    else
                        if (high > box.get_bottom(value._box))
                            box.set_bgcolor(value._box, mitigatedFvgColor)    

                            // Mitigated FVG Alert
                            if (not value._isMitigated)
                                alert("FVG has been mitigated", alert.freq_once_per_bar)
                                value._isMitigated := true

                            // Reduce FVG if needed
                            if (isMitigatedFvgToReduce)
                                box.set_text(value._box, value.tf_label + "X")
                                box.set_text_formatting(value._box, text.format_italic)
                                box.set_bottom(value._box, high)

                        box.set_right(value._box, bar_index + value.tf_num * fvgTFDistance)
                        0
    0

// 执行FVG检测和绘制
if isFvgToShow
    int tf_num = 0
    if tf8_show
        findFVGs(7, tf8, tf8_label, tf_num, fvgBox8)
        tf_num := tf_num + 1
    if tf7_show
        findFVGs(6, tf7, tf7_label, tf_num, fvgBox7)
        tf_num := tf_num + 1
    if tf6_show
        findFVGs(5, tf6, tf6_label, tf_num, fvgBox6)
        tf_num := tf_num + 1
    if tf5_show
        findFVGs(4, tf5, tf5_label, tf_num, fvgBox5)
        tf_num := tf_num + 1
    if tf4_show
        findFVGs(3, tf4, tf4_label, tf_num, fvgBox4)
        tf_num := tf_num + 1
    if tf3_show
        findFVGs(2, tf3, tf3_label, tf_num, fvgBox3)
        tf_num := tf_num + 1
    if tf2_show
        findFVGs(1, tf2, tf2_label, tf_num, fvgBox2)
        tf_num := tf_num + 1
    if tf1_show
        findFVGs(0, tf1, tf1_label, tf_num, fvgBox1)
        tf_num := tf_num + 1
    FVGDraw()

// ============================================================================
// === 参数设置 ===
// ============================================================================
// === 策略开关 ===
enableLong = input.bool(true, "启用做多", tooltip="开启做多功能（默认开启）", group="策略开关")
enableShort = input.bool(true, "启用做空", tooltip="开启做空功能（默认开启）", group="策略开关")

// === 摆动点参数 ===
pivotLength4H = input.int(5, "4H摆动点周期", minval=1, tooltip="用于4H级别摆动高低点检测的周期", group="摆动点参数")
pivotLength5M = input.int(15, "5M摆动点周期", minval=1, tooltip="用于5M级别摆动高低点检测的周期", group="摆动点参数")

// === 止损止盈参数 ===
avgHeightLength = input.int(21, "K线平均高度周期", minval=1, tooltip="用于计算止损的K线平均高度周期", group="止损止盈参数")
riskRewardRatio = input.float(3.0, "盈亏比", minval=0.1, step=0.1, tooltip="盈亏比，默认为3.0", group="止损止盈参数")

// === 移动止损参数 ===
enableTrailingStop = input.bool(true, "启用移动止损", tooltip="开启移动止损功能（默认开启）", group="移动止损参数")
// 固定几个盈亏比触发点
var float[] trailingStopLevels = array.from(1.0, 1.5, 2.0, 2.5)

// === 仓位管理参数（以损定仓） ===
enableRiskBasedSizing = input.bool(false, "启用以损定仓", tooltip="开启后按照最大亏损占比计算下单仓位", group="仓位管理")
riskPerTradePercent = input.float(1.0, "最大亏损占比(%)", minval=0.1, maxval=100, step=0.1, tooltip="单笔允许亏损占账户权益的百分比，默认1%", group="仓位管理")
riskPerTradeFraction = riskPerTradePercent * 0.01

calcRiskBasedQty(entryPrice, stopPrice) =>
    // 解方程式：(math.abs(开单价格 - 止损价格) / 止损价格) * (开单仓位的数量 * 开单价格) = 单笔风险
    // 得出：开单仓位的数量 = 单笔风险 * 止损价格 / (开单价格 * math.abs(开单价格 - 止损价格))
    usableCapital = math.max(strategy.initial_capital, strategy.equity)
    stopDistance = math.abs(entryPrice - stopPrice)
    if stopDistance <= 0 or entryPrice <= 0 or stopPrice <= 0 or usableCapital <= 0
        na
    else
        riskAmount = usableCapital * riskPerTradeFraction
        // 根据方程式计算仓位数量
        qty = (riskAmount * stopPrice) / (entryPrice * stopDistance)
        // 限制最大仓位不超过可用资金
        maxQtyByCapital = usableCapital / entryPrice
        math.min(qty, maxQtyByCapital)

// ============================================================================
// === 多时间框架数据获取 ===
// ============================================================================
// 获取4H级别的数据（一次性 request.security，在全局作用域调用）
// 返回的是 4H 序列
get4HData() =>
    [htf_high, htf_low, htf_close, htf_time] = request.security(syminfo.tickerid, "240", [high, low, close, time], lookahead=barmerge.lookahead_off)
    [htf_high, htf_low, htf_close, htf_time]

// 获取5M级别的数据（当前图表数据）
get5MData() =>
    [high, low, close, time]

// 4H 数据序列
[htf_high, htf_low, htf_close, htf_time] = get4HData()

// ============================================================================
// === 摆动高低点检测 ===
// ============================================================================
// 检测4H K线是否刚收盘（通过time的变化来判断）
var int last_htf_time = 0
is_4h_bar_closed = false
current_htf_time = request.security(syminfo.tickerid, "240", time, lookahead=barmerge.lookahead_off)
if current_htf_time != last_htf_time
    is_4h_bar_closed := true
    last_htf_time := current_htf_time

// 4H级别摆动高低点（注意：在 security 的表达式内使用 ta.pivot*）
// pivot会在确认时返回非na值，但我们需要确保只在4H K线收盘时处理
htf_ph_raw = request.security(syminfo.tickerid, "240", ta.pivothigh(high, pivotLength4H, pivotLength4H), lookahead=barmerge.lookahead_off)
htf_pl_raw = request.security(syminfo.tickerid, "240", ta.pivotlow(low, pivotLength4H, pivotLength4H), lookahead=barmerge.lookahead_off)

// 只在4H K线收盘时确认pivot
htf_ph = is_4h_bar_closed ? htf_ph_raw : na
htf_pl = is_4h_bar_closed ? htf_pl_raw : na

// 存储4H级别的摆动高低点
var float[] htf_swing_highs = array.new<float>()
var float[] htf_swing_lows  = array.new<float>()
var int[]   htf_swing_high_bars = array.new<int>()
var int[]   htf_swing_low_bars  = array.new<int>()

// 存储5M级别的摆动高低点
var float[] ltf_swing_highs = array.new<float>()
var float[] ltf_swing_lows  = array.new<float>()
var int[]   ltf_swing_high_bars = array.new<int>()
var int[]   ltf_swing_low_bars  = array.new<int>()

// ============================================================================
// === 4H摆动点检测（完全参考5M实现方式） ===
// ============================================================================
// 完全按照5M的方式实现，确保逻辑一致
var float htf_phy = na
var float htf_ply = na

// 参考5M实现：获取4H pivot实际发生的4H bar_index（类似5M的 n[pivotLength5M]）
// 4H pivot实际发生在 4H bar_index - pivotLength4H 的位置
htf_n_4h = request.security(syminfo.tickerid, "240", bar_index, lookahead=barmerge.lookahead_off)
htf_ph_bar_4h = request.security(syminfo.tickerid, "240", bar_index - pivotLength4H, lookahead=barmerge.lookahead_off)

// 获取4H pivot实际发生的4H时间，用于转换为当前图表的bar_index
htf_ph_time_4h = request.security(syminfo.tickerid, "240", time[pivotLength4H], lookahead=barmerge.lookahead_off)
htf_pl_time_4h = request.security(syminfo.tickerid, "240", time[pivotLength4H], lookahead=barmerge.lookahead_off)

// 参考5M实现：使用 if not na(htf_ph) 和 else if not na(htf_pl)
// 注意：4H pivot只在4H K线收盘时检测，所以这里htf_ph/htf_pl已经是经过is_4h_bar_closed过滤的
if not na(htf_ph)
    // 参考5M实现：H = ph > phy ? 'HH' : 'LH'
    htf_H = htf_ph > htf_phy ? 'HH' : 'LH'
    
    // 存储摆动高点（用于策略逻辑）
    array.push(htf_swing_highs, htf_ph)
    htf_ph_bar_4h = request.security(syminfo.tickerid, "240", bar_index - pivotLength4H, lookahead=barmerge.lookahead_off)
    array.push(htf_swing_high_bars, htf_ph_bar_4h)
    if array.size(htf_swing_highs) > 10
        array.shift(htf_swing_highs)
        array.shift(htf_swing_high_bars)
    
    // 获取4H pivot实际发生的4H时间，然后转换为当前图表的bar_index
    htf_ph_time_4h = request.security(syminfo.tickerid, "240", time[pivotLength4H], lookahead=barmerge.lookahead_off)
    // 在当前图表中找到对应时间的bar_index（参考5M的 n[pivotLength5M] 逻辑）
    htf_ph_bar_current = bar_index
    for i = 0 to 500
        if time[i] <= htf_ph_time_4h and (i == 0 or time[i - 1] > htf_ph_time_4h)
            htf_ph_bar_current := bar_index - i
            break
    
    // 参考5M实现：label.new(n[length], ph, H, ...)（字体大一点，使用size.small）
    label.new(htf_ph_bar_current, htf_ph, htf_H, color=color(na), style=label.style_label_down, textcolor=color.red, size=size.small)
    
    // 参考5M实现：phy := ph
    htf_phy := htf_ph

else if not na(htf_pl)
    // 参考5M实现：L = pl < ply ? 'LL' : 'HL'
    htf_L = htf_pl < htf_ply ? 'LL' : 'HL'
    
    // 存储摆动低点（用于策略逻辑）
    array.push(htf_swing_lows, htf_pl)
    htf_pl_bar_4h = request.security(syminfo.tickerid, "240", bar_index - pivotLength4H, lookahead=barmerge.lookahead_off)
    array.push(htf_swing_low_bars, htf_pl_bar_4h)
    if array.size(htf_swing_lows) > 10
        array.shift(htf_swing_lows)
        array.shift(htf_swing_low_bars)
    
    // 获取4H pivot实际发生的4H时间，然后转换为当前图表的bar_index
    htf_pl_time_4h = request.security(syminfo.tickerid, "240", time[pivotLength4H], lookahead=barmerge.lookahead_off)
    // 在当前图表中找到对应时间的bar_index（参考5M的 n[pivotLength5M] 逻辑）
    htf_pl_bar_current = bar_index
    for i = 0 to 500
        if time[i] <= htf_pl_time_4h and (i == 0 or time[i - 1] > htf_pl_time_4h)
            htf_pl_bar_current := bar_index - i
            break
    
    // 参考5M实现：label.new(n[length], pl, L, ...)（字体大一点，使用size.small）
    label.new(htf_pl_bar_current, htf_pl, htf_L, color=color(na), style=label.style_label_up, textcolor=color.green, size=size.small)
    
    // 参考5M实现：ply := pl
    htf_ply := htf_pl

// ============================================================================
// === 5M摆动点检测（完全复制参考文件逻辑） ===
// ============================================================================
// 完全按照参考文件的方式实现
var float ltf_phy = na
var float ltf_ply = na

// 参考文件：o = open[length], h = high[length], l = low[length], c = close[length]
ltf_o = open[pivotLength5M]
ltf_h = high[pivotLength5M]
ltf_l = low[pivotLength5M]
ltf_c = close[pivotLength5M]

// 参考文件：ph = ta.pivothigh(length, length), pl = ta.pivotlow(length, length)
// 注意：参考文件中使用的是 ta.pivothigh(length, length)，但标准用法应该是 ta.pivothigh(high, length, length)
// 我们使用标准用法
ltf_ph = ta.pivothigh(high, pivotLength5M, pivotLength5M)
ltf_pl = ta.pivotlow(low, pivotLength5M, pivotLength5M)

// 参考文件：n = bar_index
ltf_n = bar_index

// 参考文件：if not na(ph) ... else if not na(pl)
if not na(ltf_ph)
    // 参考文件：H = ph > phy ? 'HH' : 'LH'
    ltf_H = ltf_ph > ltf_phy ? 'HH' : 'LH'
    
    // 存储摆动高点（用于策略逻辑）
    array.push(ltf_swing_highs, ltf_ph)
    pivot_bar = ltf_n[pivotLength5M]
    array.push(ltf_swing_high_bars, pivot_bar)
    if array.size(ltf_swing_highs) > 10
        array.shift(ltf_swing_highs)
        array.shift(ltf_swing_high_bars)
    
    // 参考文件：label.new(n[length], ph, H + "\n" + ..., ...)
    label.new(ltf_n[pivotLength5M], ltf_ph, ltf_H, color=color(na), style=label.style_label_down, textcolor=color.orange, size=size.tiny)
    
    // 参考文件：phy := ph
    ltf_phy := ltf_ph

else if not na(ltf_pl)
    // 参考文件：L = pl < ply ? 'LL' : 'HL'
    ltf_L = ltf_pl < ltf_ply ? 'LL' : 'HL'
    
    // 存储摆动低点（用于策略逻辑）
    array.push(ltf_swing_lows, ltf_pl)
    pivot_bar = ltf_n[pivotLength5M]
    array.push(ltf_swing_low_bars, pivot_bar)
    if array.size(ltf_swing_lows) > 10
        array.shift(ltf_swing_lows)
        array.shift(ltf_swing_low_bars)
    
    // 参考文件：label.new(n[length], pl, L + "\n" + ..., ...)
    label.new(ltf_n[pivotLength5M], ltf_pl, ltf_L, color=color(na), style=label.style_label_up, textcolor=color.blue, size=size.tiny)
    
    // 参考文件：ply := pl
    ltf_ply := ltf_pl

// 获取最近与上一个摆动点
getLatestSwingHigh(swing_highs) =>
    array.size(swing_highs) > 0 ? array.get(swing_highs, array.size(swing_highs) - 1) : na

getLatestSwingLow(swing_lows) =>
    array.size(swing_lows) > 0 ? array.get(swing_lows, array.size(swing_lows) - 1) : na

getPrevSwingHigh(swing_highs) =>
    array.size(swing_highs) > 1 ? array.get(swing_highs, array.size(swing_highs) - 2) : na

getPrevSwingLow(swing_lows) =>
    array.size(swing_lows) > 1 ? array.get(swing_lows, array.size(swing_lows) - 2) : na

// 4H级别最近的摆动点
htf_latest_high = getLatestSwingHigh(htf_swing_highs)
htf_latest_low  = getLatestSwingLow(htf_swing_lows)
htf_prev_high   = getPrevSwingHigh(htf_swing_highs)
htf_prev_low    = getPrevSwingLow(htf_swing_lows)

// 5M级别最近的摆动点
ltf_latest_high = getLatestSwingHigh(ltf_swing_highs)
ltf_latest_low  = getLatestSwingLow(ltf_swing_lows)
ltf_prev_high   = getPrevSwingHigh(ltf_swing_highs)
ltf_prev_low    = getPrevSwingLow(ltf_swing_lows)


// ============================================================================
// === 顶顶高/底底高结构检测 ===
// ============================================================================
// 4H级别：最近摆动高点 > 上一个摆动高点 且 最近摆动低点 > 上一个摆动低点
htf_higher_high      = not na(htf_latest_high) and not na(htf_prev_high) and htf_latest_high > htf_prev_high
htf_higher_low       = not na(htf_latest_low)  and not na(htf_prev_low)  and htf_latest_low  > htf_prev_low
htf_structure_bullish = htf_higher_high and htf_higher_low

// 5M级别：最近摆动高点 > 上一个摆动高点 且 最近摆动低点 > 上一个摆动低点
ltf_higher_high      = not na(ltf_latest_high) and not na(ltf_prev_high) and ltf_latest_high > ltf_prev_high
ltf_higher_low       = not na(ltf_latest_low)  and not na(ltf_prev_low)  and ltf_latest_low  > ltf_prev_low
ltf_structure_bullish = ltf_higher_high and ltf_higher_low

// ============================================================================
// 从参考文件的FVG数组中获取4H和5M的FVG数据用于策略逻辑

// 获取4H级别最近的向上FVG（从fvgBox3数组）
getLatest4HBullishFVG() =>
    float fvg_top = na
    float fvg_bottom = na
    int fvg_left = na
    bool fvg_found = false
    
    if array.size(fvgBox3) > 0
        // 从后往前查找最近的向上FVG
        for i = array.size(fvgBox3) - 1 to 0
            fvg = array.get(fvgBox3, i)
            if fvg._type == true  // 向上FVG
                fvg_top := fvg.top
                fvg_bottom := fvg.bottom
                fvg_left := fvg.left
                fvg_found := true
                break
    
    [fvg_found, fvg_top, fvg_bottom, fvg_left]

// 获取5M级别最近的向上FVG（从fvgBox1数组）
getLatest5MBullishFVG() =>
    float fvg_top = na
    float fvg_bottom = na
    bool fvg_found = false
    
    if array.size(fvgBox1) > 0
        // 从后往前查找最近的向上FVG
        for i = array.size(fvgBox1) - 1 to 0
            fvg = array.get(fvgBox1, i)
            if fvg._type == true  // 向上FVG
                fvg_top := fvg.top
                fvg_bottom := fvg.bottom
                fvg_found := true
                break
    
    [fvg_found, fvg_top, fvg_bottom]

// 获取4H级别最近的向下FVG（从fvgBox3数组）
getLatest4HBearishFVG() =>
    float fvg_top = na
    float fvg_bottom = na
    int fvg_left = na
    bool fvg_found = false
    
    if array.size(fvgBox3) > 0
        // 从后往前查找最近的向下FVG
        for i = array.size(fvgBox3) - 1 to 0
            fvg = array.get(fvgBox3, i)
            if fvg._type == false  // 向下FVG
                fvg_top := fvg.top
                fvg_bottom := fvg.bottom
                fvg_left := fvg.left
                fvg_found := true
                break
    
    [fvg_found, fvg_top, fvg_bottom, fvg_left]

// 获取5M级别最近的向下FVG（从fvgBox1数组）
getLatest5MBearishFVG() =>
    float fvg_top = na
    float fvg_bottom = na
    bool fvg_found = false
    
    if array.size(fvgBox1) > 0
        // 从后往前查找最近的向下FVG
        for i = array.size(fvgBox1) - 1 to 0
            fvg = array.get(fvgBox1, i)
            if fvg._type == false  // 向下FVG
                fvg_top := fvg.top
                fvg_bottom := fvg.bottom
                fvg_found := true
                break
    
    [fvg_found, fvg_top, fvg_bottom]

// 获取4H和5M的FVG数据（做多）
[htf_fvg_detected, htf_fvg_top, htf_fvg_bottom, htf_fvg_left] = getLatest4HBullishFVG()
[ltf_fvg_detected, ltf_fvg_top, ltf_fvg_bottom] = getLatest5MBullishFVG()

// 获取4H和5M的FVG数据（做空）
[htf_bearish_fvg_detected, htf_bearish_fvg_top, htf_bearish_fvg_bottom, htf_bearish_fvg_left] = getLatest4HBearishFVG()
[ltf_bearish_fvg_detected, ltf_bearish_fvg_top, ltf_bearish_fvg_bottom] = getLatest5MBearishFVG()


// ============================================================================
// === 做多准备条件检测 ===
// ============================================================================
// 1. 切换到4h级别k线图，寻找到最近摆动高低点（已通过摆动点检测完成）

// 2. 当前4h级别k线收盘时，回溯从当前k线到最近的摆动低点是否有向上的4h级别的fvg形成
htf_latest_low_price = getLatestSwingLow(htf_swing_lows)
htf_latest_low_bar = array.size(htf_swing_low_bars) > 0 ? array.get(htf_swing_low_bars, array.size(htf_swing_low_bars) - 1) : na

// 检查4H级别FVG是否在最近摆动低点之后形成（FVG的left应该在最近摆动低点的bar_index之后）
htf_fvg_after_swing_low = false
if htf_fvg_detected and not na(htf_latest_low_bar) and array.size(fvgBox3) > 0
    for i = array.size(fvgBox3) - 1 to 0
        fvg = array.get(fvgBox3, i)
        if fvg._type == true  // 向上FVG
            // FVG的left（起始bar_index）应该在最近摆动低点的bar_index之后
            if fvg.left >= htf_latest_low_bar
                htf_fvg_after_swing_low := true
                break

// 3. 价格回测到4H级别有效的FVG（当前价格在FVG范围内）
htf_price_in_fvg = false
if htf_fvg_detected and not na(htf_fvg_bottom) and not na(htf_fvg_top)
    htf_price_in_fvg := close >= htf_fvg_bottom and close <= htf_fvg_top

// 做多准备条件：只需要FVG在摆动低点后形成，且价格回测到FVG
readyForLong = htf_fvg_after_swing_low and htf_price_in_fvg

// ============================================================================
// === 准备做多失效条件 ===
// ============================================================================
// 1. 价格突破4H级别的摆动高点或跌破摆动低点时做多条件失效
htf_break_high = not na(htf_latest_high) and close > htf_latest_high
htf_break_low = not na(htf_latest_low_price) and close < htf_latest_low_price
htf_breakout = htf_break_high or htf_break_low

// 2. 价格在该摆动高低点区间内形成4H级别向下的FVG时做多条件失效
htf_bearish_fvg_in_range = false
if not na(htf_latest_high) and not na(htf_latest_low_price) and array.size(fvgBox3) > 0
    for i = array.size(fvgBox3) - 1 to 0
        fvg = array.get(fvgBox3, i)
        if fvg._type == false  // 向下FVG
            // 检查FVG是否在摆动高低点区间内
            if fvg.bottom >= htf_latest_low_price and fvg.top <= htf_latest_high
                htf_bearish_fvg_in_range := true
                break

// 准备做多失效
readyForLongInvalid = htf_breakout or htf_bearish_fvg_in_range

// ============================================================================
// === 做多入场条件检测（5M） ===
// ============================================================================
// 条件1：5M级别最近摆动低点 < 4H级别FVG上沿，并且当前收盘价 > 4H级别FVG下沿
condition1 = not na(ltf_latest_low) and not na(htf_fvg_top) and not na(htf_fvg_bottom) and ltf_latest_low < htf_fvg_top and close > htf_fvg_bottom

// 条件2：当前5分钟级别k线收盘时，回溯从当前k线到最近的摆动低点是否有向上的5分钟级别的fvg形成
ltf_latest_low_bar = array.size(ltf_swing_low_bars) > 0 ? array.get(ltf_swing_low_bars, array.size(ltf_swing_low_bars) - 1) : na

// 检查5M级别FVG是否在最近摆动低点之后形成（FVG的left应该在最近摆动低点的bar_index之后）
ltf_fvg_after_swing_low = false
if ltf_fvg_detected and not na(ltf_latest_low_bar) and array.size(fvgBox1) > 0
    for i = array.size(fvgBox1) - 1 to 0
        fvg = array.get(fvgBox1, i)
        if fvg._type == true  // 向上FVG
            // FVG的left（起始bar_index）应该在最近摆动低点的bar_index之后
            if fvg.left >= ltf_latest_low_bar
                ltf_fvg_after_swing_low := true
                break

condition2 = ltf_fvg_after_swing_low

// 条件4：当前4h级别fvg仍然有效（有k线的low低于该4hfvg的下沿视为失效）
// 检查当前时间框架（5分钟）K线的low是否低于4H FVG下沿
htf_fvg_still_valid = false
if htf_fvg_detected and not na(htf_fvg_bottom)
    // 检查当前K线的low是否低于4H FVG下沿
    // 如果当前K线的low低于FVG下沿，则FVG失效
    if not na(low) and low < htf_fvg_bottom
        htf_fvg_still_valid := false
    else
        htf_fvg_still_valid := true

condition3 = htf_fvg_still_valid

// 做多入场条件：只有在准备做多条件满足且未失效时才入场
// 确保没有持仓时才能开新单
// 注意：condition3（FVG有效性）只用于入场条件，不会导致已持仓订单平仓
// 平仓的唯一标准是：止盈（价格到达止盈价格）或止损（价格触发止损价格）
longEntryCondition = enableLong and readyForLong and not readyForLongInvalid and condition1 and condition2 and condition3 and strategy.position_size == 0

// ============================================================================
// === 止损和止盈计算 ===
// ============================================================================
// 计算最近N根K线的平均高度
var float avgCandleHeight = na
if bar_index >= avgHeightLength - 1
    sumHeight = 0.0
    for i = 0 to avgHeightLength - 1
        sumHeight += high[i] - low[i]
    avgCandleHeight := sumHeight / avgHeightLength
else if bar_index >= 0
    sumHeight = 0.0
    for i = 0 to bar_index
        sumHeight += high[i] - low[i]
    avgCandleHeight := sumHeight / (bar_index + 1)

// 止损/止盈变量
var float longStopLoss     = na
var float longEntryPrice   = na
var float initialStopLoss  = na  // 初始止损，用于移动止损计算
var float longTakeProfit   = na  // 止盈价格
var bool longEntryExecuted = false  // 跟踪是否已执行做多开仓
// 止损止盈线段
var line longStopLossLine = na
var line longTakeProfitLine = na
// 4H FVG标识矩形数组（做多，不删除，保留所有历史框）
var array<box> longFvgBoxes = array.new<box>()
// 开仓位置矩形数组（做多，白色框，下边框为止损，上边框为止盈，不删除）
var array<box> longEntryBoxes = array.new<box>()

// 开仓时设置止损和止盈
// 确保没有持仓且未在同一根K线上重复开仓
if longEntryCondition and strategy.position_size == 0 and not longEntryExecuted
    longEntryPrice := close
    longStopLoss   := not na(ltf_latest_low) and not na(avgCandleHeight) ? ltf_latest_low - avgCandleHeight : na
    initialStopLoss := longStopLoss
    longEntryExecuted := true

    // 计算以损定仓的仓位
    longQtyForEntry = enableRiskBasedSizing ? calcRiskBasedQty(longEntryPrice, longStopLoss) : na
    // 如果启用了以损定仓但计算失败，不开仓（避免使用默认100%仓位导致margin call）
    // 只有在未启用以损定仓，或者启用了但计算成功时，才开仓
    if not (enableRiskBasedSizing and na(longQtyForEntry))
        // 计算止盈价格并保存
        longTakeProfit := not na(longEntryPrice) and not na(longStopLoss) ? longEntryPrice + (longEntryPrice - longStopLoss) * riskRewardRatio : na
        
        // 删除旧的止损止盈线段（如果存在）
        if not na(longStopLossLine)
            line.delete(longStopLossLine)
        if not na(longTakeProfitLine)
            line.delete(longTakeProfitLine)
        
        // 创建止损线段（红色）
        if not na(longStopLoss)
            longStopLossLine := line.new(x1=bar_index, y1=longStopLoss, x2=bar_index + 10, y2=longStopLoss, color=color.red, width=2, style=line.style_solid)
        
        // 创建止盈线段（绿色）
        if not na(longTakeProfit)
            longTakeProfitLine := line.new(x1=bar_index, y1=longTakeProfit, x2=bar_index + 10, y2=longTakeProfit, color=color.green, width=2, style=line.style_solid)
        
        // 创建4H向上FVG标识矩形（橙色框，从开仓位置开始，宽度10根K线，不删除）
        if htf_fvg_detected and not na(htf_fvg_top) and not na(htf_fvg_bottom) and not na(htf_fvg_left)
            fvgBox = box.new(left=bar_index, top=htf_fvg_top, right=bar_index + 10, bottom=htf_fvg_bottom, border_color=color.new(color.orange, 0), border_width=1, bgcolor=color.new(color.orange, 90), extend=extend.none, text="4H FVG", text_color=color.orange, text_size=size.small)
            array.push(longFvgBoxes, fvgBox)
        
        // 创建开仓位置白色矩形（下边框为止损，上边框为止盈，不删除）
        if not na(longStopLoss) and not na(longTakeProfit)
            entryBox = box.new(left=bar_index, top=longTakeProfit, right=bar_index + 10, bottom=longStopLoss, border_color=color.new(color.white, 0), border_width=1, bgcolor=color.new(color.white, 90), extend=extend.none)
            array.push(longEntryBoxes, entryBox)
        
        strategy.entry("Long", strategy.long, qty=enableRiskBasedSizing and not na(longQtyForEntry) ? longQtyForEntry : na, comment="做多")

// 当没有持仓时，重置开仓标志
if strategy.position_size == 0
    longEntryExecuted := false

// ============================================================================
// === 移动止损逻辑 ===
// ============================================================================

if enableTrailingStop and strategy.position_size > 0 and not na(longEntryPrice) and not na(initialStopLoss)
    currentProfit = close - longEntryPrice
    currentRisk   = longEntryPrice - initialStopLoss
    currentRR     = currentRisk > 0 ? currentProfit / currentRisk : 0.0

    shouldTrail = false
    // 遍历 trailingStopLevels 数组（用索引）
    for i = 0 to array.size(trailingStopLevels) - 1
        level = array.get(trailingStopLevels, i)
        if currentRR >= level
            shouldTrail := true

    // 如果达到触发点，移动止损到 5M 最近摆动低点 - avgHeight
    if shouldTrail and not na(ltf_latest_low) and not na(avgCandleHeight)
        newStopLoss = ltf_latest_low - avgCandleHeight
        if not na(newStopLoss) and (na(longStopLoss) or newStopLoss > longStopLoss)
            longStopLoss := newStopLoss

// ============================================================================
// === 止损和止盈执行 ===
// ============================================================================
// === 止损和止盈执行 ===
// ============================================================================
// 注意：平仓的唯一标准是止盈或止损，不会因为FVG失效而平仓
// 止盈：价格到达止盈价格时立即平仓
if strategy.position_size > 0 and not na(longTakeProfit)
    // 对于做多，当价格涨到止盈价格或以上时，平仓
    if close >= longTakeProfit
        strategy.close("Long", comment="止盈")
        longEntryPrice  := na
        longStopLoss    := na
        initialStopLoss := na
        longTakeProfit  := na
        // 删除止损止盈线段
        if not na(longStopLossLine)
            line.delete(longStopLossLine)
            longStopLossLine := na
        if not na(longTakeProfitLine)
            line.delete(longTakeProfitLine)
            longTakeProfitLine := na

// 止损：使用 strategy.exit
if strategy.position_size > 0 and not na(longStopLoss)
    strategy.exit("Long Exit", "Long", stop=longStopLoss)

// 当持仓变为0时，清理止损止盈线段（止损触发时）
if strategy.position_size == 0 and not na(longStopLossLine)
    line.delete(longStopLossLine)
    longStopLossLine := na
if strategy.position_size == 0 and not na(longTakeProfitLine)
    line.delete(longTakeProfitLine)
    longTakeProfitLine := na

// ============================================================================
// === 做空准备条件检测 ===
// ============================================================================
// 1. 切换到4h级别k线图，寻找到最近摆动高低点（已通过摆动点检测完成）

// 2. 当前4h级别k线收盘时，回溯从当前k线到最近的摆动高点是否有向下的4h级别的fvg形成
htf_latest_high_price = getLatestSwingHigh(htf_swing_highs)
htf_latest_high_bar = array.size(htf_swing_high_bars) > 0 ? array.get(htf_swing_high_bars, array.size(htf_swing_high_bars) - 1) : na

// 检查4H级别向下FVG是否在最近摆动高点之后形成（FVG的left应该在最近摆动高点的bar_index之后）
htf_bearish_fvg_after_swing_high = false
if htf_bearish_fvg_detected and not na(htf_latest_high_bar) and array.size(fvgBox3) > 0
    for i = array.size(fvgBox3) - 1 to 0
        fvg = array.get(fvgBox3, i)
        if fvg._type == false  // 向下FVG
            // FVG的left（起始bar_index）应该在最近摆动高点的bar_index之后
            if fvg.left >= htf_latest_high_bar
                htf_bearish_fvg_after_swing_high := true
                break

// 3. 价格回测到4H级别有效的向下FVG（当前价格在FVG范围内）
htf_bearish_price_in_fvg = false
if htf_bearish_fvg_detected and not na(htf_bearish_fvg_bottom) and not na(htf_bearish_fvg_top)
    htf_bearish_price_in_fvg := close >= htf_bearish_fvg_bottom and close <= htf_bearish_fvg_top

// 做空准备条件：只需要向下FVG在摆动高点后形成，且价格回测到FVG
readyForShort = htf_bearish_fvg_after_swing_high and htf_bearish_price_in_fvg

// ============================================================================
// === 准备做空失效条件 ===
// ============================================================================
// 1. 价格突破4H级别的摆动低点或突破摆动高点时做空条件失效
htf_short_break_high = not na(htf_latest_high_price) and close > htf_latest_high_price
htf_short_break_low = not na(htf_latest_low_price) and close < htf_latest_low_price
htf_short_breakout = htf_short_break_high or htf_short_break_low

// 2. 价格在该摆动高低点区间内形成4H级别向上的FVG时做空条件失效
htf_bullish_fvg_in_range = false
if not na(htf_latest_high_price) and not na(htf_latest_low_price) and array.size(fvgBox3) > 0
    for i = array.size(fvgBox3) - 1 to 0
        fvg = array.get(fvgBox3, i)
        if fvg._type == true  // 向上FVG
            // 检查FVG是否在摆动高低点区间内
            if fvg.bottom >= htf_latest_low_price and fvg.top <= htf_latest_high_price
                htf_bullish_fvg_in_range := true
                break

// 准备做空失效
readyForShortInvalid = htf_short_breakout or htf_bullish_fvg_in_range

// ============================================================================
// === 做空入场条件检测（5M） ===
// ============================================================================
// 条件1：5M级别最近摆动高点 > 4H级别FVG下沿，并且当前收盘价 < 4H级别FVG上沿
short_condition1 = not na(ltf_latest_high) and not na(htf_bearish_fvg_top) and not na(htf_bearish_fvg_bottom) and ltf_latest_high > htf_bearish_fvg_bottom and close < htf_bearish_fvg_top

// 条件2：当前5分钟级别k线收盘时，回溯从当前k线到最近的摆动高点是否有向下的5分钟级别的fvg形成
ltf_latest_high_bar = array.size(ltf_swing_high_bars) > 0 ? array.get(ltf_swing_high_bars, array.size(ltf_swing_high_bars) - 1) : na

// 检查5M级别向下FVG是否在最近摆动高点之后形成（FVG的left应该在最近摆动高点的bar_index之后）
ltf_bearish_fvg_after_swing_high = false
if ltf_bearish_fvg_detected and not na(ltf_latest_high_bar) and array.size(fvgBox1) > 0
    for i = array.size(fvgBox1) - 1 to 0
        fvg = array.get(fvgBox1, i)
        if fvg._type == false  // 向下FVG
            // FVG的left（起始bar_index）应该在最近摆动高点的bar_index之后
            if fvg.left >= ltf_latest_high_bar
                ltf_bearish_fvg_after_swing_high := true
                break

short_condition2 = ltf_bearish_fvg_after_swing_high

// 条件3：当前4h级别向下fvg仍然有效（有k线的high高于该4hfvg的上沿视为失效）
// 检查当前时间框架（5分钟）K线的high是否高于4H向下FVG上沿
htf_bearish_fvg_still_valid = false
if htf_bearish_fvg_detected and not na(htf_bearish_fvg_top)
    // 检查当前K线的high是否高于4H FVG上沿
    // 如果当前K线的high高于FVG上沿，则FVG失效
    if not na(high) and high > htf_bearish_fvg_top
        htf_bearish_fvg_still_valid := false
    else
        htf_bearish_fvg_still_valid := true

short_condition3 = htf_bearish_fvg_still_valid

// 做空入场条件：只有在准备做空条件满足且未失效时才入场
// 确保没有持仓时才能开新单
// 注意：short_condition3（FVG有效性）只用于入场条件，不会导致已持仓订单平仓
// 平仓的唯一标准是：止盈（价格到达止盈价格）或止损（价格触发止损价格）
shortEntryCondition = enableShort and readyForShort and not readyForShortInvalid and short_condition1 and short_condition2 and short_condition3 and strategy.position_size == 0

// ============================================================================
// === 做空止损和止盈计算 ===
// ============================================================================
// 止损/止盈变量（做空）
var float shortStopLoss     = na
var float shortEntryPrice   = na
var float shortInitialStopLoss  = na  // 初始止损，用于移动止损计算
var float shortTakeProfit   = na  // 止盈价格
var bool shortEntryExecuted = false  // 跟踪是否已执行做空开仓
// 止损止盈线段（做空）
var line shortStopLossLine = na
var line shortTakeProfitLine = na
// 4H FVG标识矩形数组（做空，不删除，保留所有历史框）
var array<box> shortFvgBoxes = array.new<box>()
// 开仓位置矩形数组（做空，白色框，下边框为止盈，上边框为止损，不删除）
var array<box> shortEntryBoxes = array.new<box>()

// 开仓时设置止损和止盈
// 确保没有持仓且未在同一根K线上重复开仓
if shortEntryCondition and strategy.position_size == 0 and not shortEntryExecuted
    shortEntryPrice := close
    shortStopLoss   := not na(ltf_latest_high) and not na(avgCandleHeight) ? ltf_latest_high + avgCandleHeight : na
    shortInitialStopLoss := shortStopLoss
    shortEntryExecuted := true

    // 计算以损定仓的仓位
    shortQtyForEntry = enableRiskBasedSizing ? calcRiskBasedQty(shortEntryPrice, shortStopLoss) : na

    // 如果启用了以损定仓但计算失败，不开仓（避免使用默认100%仓位导致margin call）
    // 只有在未启用以损定仓，或者启用了但计算成功时，才开仓
    if not (enableRiskBasedSizing and na(shortQtyForEntry))
        // 计算止盈价格并保存
        shortTakeProfit := not na(shortEntryPrice) and not na(shortStopLoss) ? shortEntryPrice - (shortStopLoss - shortEntryPrice) * riskRewardRatio : na
        
        // 删除旧的止损止盈线段（如果存在）
        if not na(shortStopLossLine)
            line.delete(shortStopLossLine)
        if not na(shortTakeProfitLine)
            line.delete(shortTakeProfitLine)
        
        // 创建止损线段（红色）
        if not na(shortStopLoss)
            shortStopLossLine := line.new(x1=bar_index, y1=shortStopLoss, x2=bar_index + 10, y2=shortStopLoss, color=color.red, width=2, style=line.style_solid)
        
        // 创建止盈线段（绿色）
        if not na(shortTakeProfit)
            shortTakeProfitLine := line.new(x1=bar_index, y1=shortTakeProfit, x2=bar_index + 10, y2=shortTakeProfit, color=color.green, width=2, style=line.style_solid)
        
        // 创建4H向下FVG标识矩形（橙色框，从开仓位置开始，宽度10根K线，不删除）
        if htf_bearish_fvg_detected and not na(htf_bearish_fvg_top) and not na(htf_bearish_fvg_bottom) and not na(htf_bearish_fvg_left)
            fvgBox = box.new(left=bar_index, top=htf_bearish_fvg_top, right=bar_index + 10, bottom=htf_bearish_fvg_bottom, border_color=color.new(color.orange, 0), border_width=1, bgcolor=color.new(color.orange, 90), extend=extend.none, text="4H FVG", text_color=color.orange, text_size=size.small)
            array.push(shortFvgBoxes, fvgBox)

        // 创建开仓位置白色矩形（下边框为止盈，上边框为止损，不删除）
        if not na(shortStopLoss) and not na(shortTakeProfit)
            entryBox = box.new(left=bar_index, top=shortStopLoss, right=bar_index + 10, bottom=shortTakeProfit, border_color=color.new(color.white, 0), border_width=1, bgcolor=color.new(color.white, 90), extend=extend.none)
            array.push(shortEntryBoxes, entryBox)

        strategy.entry("Short", strategy.short, qty=enableRiskBasedSizing and not na(shortQtyForEntry) ? shortQtyForEntry : na, comment="做空")

// 当没有持仓时，重置开仓标志
if strategy.position_size == 0
    shortEntryExecuted := false

// ============================================================================
// === 做空移动止损逻辑 ===
// ============================================================================

if enableTrailingStop and strategy.position_size < 0 and not na(shortEntryPrice) and not na(shortInitialStopLoss)
    currentProfit = shortEntryPrice - close
    currentRisk   = shortInitialStopLoss - shortEntryPrice
    currentRR     = currentRisk > 0 ? currentProfit / currentRisk : 0.0

    shouldTrail = false
    // 遍历 trailingStopLevels 数组（用索引）
    for i = 0 to array.size(trailingStopLevels) - 1
        level = array.get(trailingStopLevels, i)
        if currentRR >= level
            shouldTrail := true

    // 如果达到触发点，移动止损到 5M 最近摆动高点 + avgHeight
    // 对于做空，止损价应该越高越好（更接近入场价，保护利润），所以用 > 而不是 <
    if shouldTrail and not na(ltf_latest_high) and not na(avgCandleHeight)
        newStopLoss = ltf_latest_high + avgCandleHeight
        if not na(newStopLoss) and (na(shortStopLoss) or newStopLoss > shortStopLoss)
            shortStopLoss := newStopLoss

// ============================================================================
// === 做空止损和止盈执行 ===
// ============================================================================
// === 做空止损和止盈执行 ===
// ============================================================================
// 注意：平仓的唯一标准是止盈或止损，不会因为FVG失效而平仓
// 止盈：价格到达止盈价格时立即平仓
if strategy.position_size < 0 and not na(shortTakeProfit)
    // 对于做空，当价格跌到止盈价格或以下时，平仓
    if close <= shortTakeProfit
        strategy.close("Short", comment="止盈")
        shortEntryPrice  := na
        shortStopLoss    := na
        shortInitialStopLoss := na
        shortTakeProfit  := na
        // 删除止损止盈线段
        if not na(shortStopLossLine)
            line.delete(shortStopLossLine)
            shortStopLossLine := na
        if not na(shortTakeProfitLine)
            line.delete(shortTakeProfitLine)
            shortTakeProfitLine := na

// 止损：使用 strategy.exit
if strategy.position_size < 0 and not na(shortStopLoss)
    strategy.exit("Short Exit", "Short", stop=shortStopLoss)

// 当持仓变为0时，清理止损止盈线段（止损触发时）
if strategy.position_size == 0 and not na(shortStopLossLine)
    line.delete(shortStopLossLine)
    shortStopLossLine := na
if strategy.position_size == 0 and not na(shortTakeProfitLine)
    line.delete(shortTakeProfitLine)
    shortTakeProfitLine := na
