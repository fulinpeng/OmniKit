//@version=5
strategy("Mult Time WaveTrend & fvg Trading Strategy", overlay=false, default_qty_type=strategy.percent_of_equity, default_qty_value=100)

n1 = input.int(10, "WT Channel Length")
n2 = input.int(21, "WT Average Length")

obLevel1 = input.int(60, "OverBought Level 1 (+60)")
obLevel2 = input.int(53, "OverBought Level 2 (+53)")
midLevelHigh = input.int(50, "看空阈值线 (+50)")
midLevelLow = input.int(-50, "看多阈值线 (-50)")
osLevel2 = input.int(-53, "OverSold Level 2 (-53)")
osLevel1 = input.int(-60, "OverSold Level 1 (-60)")

ema20 = ta.ema(close, 20)
ema50 = ta.ema(close, 50)
ema100 = ta.ema(close, 100)

enableLong = input.bool(true, "启用做多策略", tooltip="是否启用做多策略")
enableShort = input.bool(true, "启用做空策略", tooltip="是否启用做空策略")

enableRiskBasedSizing = input.bool(false, "启用以损定仓", tooltip="开启后按照最大亏损占比计算下单仓位", group="仓位管理")
riskPerTradePercent = input.float(1.0, "最大亏损占比(%)", minval=0.1, maxval=100, step=0.1, tooltip="单笔允许亏损占账户权益的百分比，默认1%", group="仓位管理")
riskPerTradeFraction = riskPerTradePercent * 0.01

calcRiskBasedQty(entryPrice, stopPrice) =>
    // 解方程式：(math.abs(开单价格 - 止损价格) / 止损价格) * (开单仓位的数量 * 开单价格) = 单笔风险
    // 得出：开单仓位的数量 = 单笔风险 * 止损价格 / (开单价格 * math.abs(开单价格 - 止损价格))
    usableCapital = math.max(strategy.initial_capital, strategy.equity)
    stopDistance = math.abs(entryPrice - stopPrice)
    if stopDistance <= 0 or entryPrice <= 0 or stopPrice <= 0 or usableCapital <= 0
        na
    else
        riskAmount = usableCapital * riskPerTradeFraction
        // 根据方程式计算仓位数量
        qty = (riskAmount * stopPrice) / (entryPrice * stopDistance)
        // 限制最大仓位不超过可用资金
        maxQtyByCapital = usableCapital / entryPrice
        math.min(qty, maxQtyByCapital)

longRiskRewardRatio = input.float(2.5, "做多盈亏比", minval=0.1, step=0.1, tooltip="做多盈亏比，默认为2.5", group="做多参数")

longP5UpperLimit = input.int(50, "做多开仓p5上限", minval=-100, maxval=100, tooltip="做多条件1的上限，可根据需要调整", group="做多参数")
longP15LowerLimit = input.int(0, "做多开仓p15下限", minval=-100, maxval=100, tooltip="做多条件2的下限，可根据需要调整（默认0）", group="做多参数")
longReadyBuyThreshold = input.int(-50, "做多readyBuy阈值", minval=-100, maxval=100, tooltip="做多readyBuy设置条件p5m1, p15m1 都小于等于该值（默认-50）", group="做多参数")
longP1h1UpperLimit = input.int(25, "做多readyBuy的p1h1上限", minval=-100, maxval=100, tooltip="做多readyBuy条件中p1h1的上限（默认25）", group="做多参数")
longThresholdLevel = input.int(50, "做多阈值水平", minval=0, tooltip="做多用于p1h1>阈值等条件（默认50）", group="做多参数")
longFvgLookbackBars = input.int(5, "做多FVG回溯K线数量", minval=3, maxval=20, tooltip="做多条件1+2+3满足时，往前推的K线数量作为FVG检测起始K线（默认5，最小3）", group="做多参数")
longFvgWaitBars = input.int(0, "做多FVG等待K线数量", minval=0, maxval=10, tooltip="做多条件1+2+3满足后，允许等待多头FVG的K线数量（默认0，最大10）", group="做多参数")
longFvgGapMultiplier = input.int(5, "做多FVG gap倍数", minval=1, maxval=10000, tooltip="做多FVG的gap必须大于当前平均K线高度的1/该倍数（默认5，最大10000）", group="做多参数")
longEnableFvgPriceCheck = input.bool(true, "做多启用FVG价格检查", tooltip="做多启用后，当前K线收盘价必须 > FVG区域最小值才能确认FVG（默认开启）", group="做多参数")
longPartialCloseLevel = input.int(55, "做多移动止损触发p5阈值", minval=0, tooltip="做多当p5m1达到该值时触发移动止损（默认55）", group="做多参数")
longBreakevenFactor = input.float(1.001, "做多保本止损系数", minval=1.0, step=0.0005, tooltip="做多移动止损到保本时使用：开仓价 * 系数（默认1.001）", group="做多参数")

longEnableProfitTarget2 = input.bool(true, "做多启用止盈条件2", tooltip="做多当p5m1和p15m1都大于阈值时立即平仓（默认开启）", group="做多参数")

longPivotLength = input.int(7, "做多摆动低点周期", minval=1, tooltip="做多用于计算摆动低点的周期长度", group="做多参数")
longAvgHeightLength = input.int(21, "做多K线平均高度周期", minval=1, tooltip="做多用于计算K线平均高度的周期长度", group="做多参数")

shortRiskRewardRatio = input.float(2.5, "做空盈亏比", minval=0.1, step=0.1, tooltip="做空盈亏比，默认为2.5", group="做空参数")

shortP5LowerLimit = input.int(-50, "做空开仓p5下限", minval=-100, maxval=100, tooltip="做空条件1的下限，可根据需要调整", group="做空参数")
shortP15UpperLimit = input.int(0, "做空开仓p15上限", minval=-100, maxval=100, tooltip="做空条件2的上限，可根据需要调整（默认0）", group="做空参数")
shortReadySellThreshold = input.int(50, "做空readySell阈值", minval=-100, maxval=100, tooltip="做空readySell设置条件p5m1, p15m1 都大于等于该值（默认50）", group="做空参数")
shortP1h1LowerLimit = input.int(-25, "做空readySell的p1h1下限", minval=-100, maxval=100, tooltip="做空readySell条件中p1h1的下限（默认-25）", group="做空参数")
shortThresholdLevel = input.int(-50, "做空阈值水平", minval=-100, maxval=0, tooltip="做空用于p1h1<阈值等条件（默认-50）", group="做空参数")
shortFvgLookbackBars = input.int(5, "做空FVG回溯K线数量", minval=3, maxval=20, tooltip="做空条件1+2+3满足时，往前推的K线数量作为FVG检测起始K线（默认5，最小3）", group="做空参数")
shortFvgWaitBars = input.int(0, "做空FVG等待K线数量", minval=0, maxval=10, tooltip="做空条件1+2+3满足后，允许等待空头FVG的K线数量（默认0，最大10）", group="做空参数")
shortFvgGapMultiplier = input.int(5, "做空FVG gap倍数", minval=1, maxval=10000, tooltip="做空FVG的gap必须大于当前平均K线高度的1/该倍数（默认5，最大10000）", group="做空参数")
shortEnableFvgPriceCheck = input.bool(true, "做空启用FVG价格检查", tooltip="做空启用后，当前K线收盘价必须 < FVG区域最大值才能确认FVG（默认开启）", group="做空参数")
shortPartialCloseLevel = input.int(-55, "做空移动止损触发p5阈值", minval=-100, maxval=0, tooltip="做空当p5m1达到该值时触发移动止损（默认-55）", group="做空参数")
shortBreakevenFactor = input.float(0.999, "做空保本止损系数", minval=0.9, maxval=1.0, step=0.0005, tooltip="做空移动止损到保本时使用：开仓价 * 系数（默认0.999）", group="做空参数")

shortEnableProfitTarget2 = input.bool(true, "做空启用止盈条件2", tooltip="做空当p5m1和p15m1都小于阈值时立即平仓（默认开启）", group="做空参数")

shortPivotLength = input.int(7, "做空摆动高点周期", minval=1, tooltip="做空用于计算摆动高点的周期长度", group="做空参数")
shortAvgHeightLength = input.int(21, "做空K线平均高度周期", minval=1, tooltip="做空用于计算K线平均高度的周期长度", group="做空参数")

showMTF = input.bool(true, "显示多时间框架WT", inline="mtf")
show4H  = input.bool(true, "4H", inline="mtf")
show1H  = input.bool(true, "1H", inline="mtf")
show15  = input.bool(true, "15m", inline="mtf")

ap = hlc3 
esa = ta.ema(ap, n1)
d = ta.ema(math.abs(ap - esa), n1)
ci = (ap - esa) / (0.015 * d)
tci = ta.ema(ci, n2)

wt1 = tci
wt2 = ta.sma(wt1, 4)

wt_calc() =>
    _ap = hlc3
    _esa = ta.ema(_ap, n1)
    _d = ta.ema(math.abs(_ap - _esa), n1)
    _ci = (_ap - _esa) / (0.015 * _d)
    _tci = ta.ema(_ci, n2)
    _wt1 = _tci
    _wt2 = ta.sma(_wt1, 4)
    [_wt1, _wt2]

[wt1_4h, wt2_4h] = request.security(syminfo.tickerid, "240", wt_calc(), lookahead=barmerge.lookahead_off)
[wt1_1h, wt2_1h] = request.security(syminfo.tickerid, "60",  wt_calc(), lookahead=barmerge.lookahead_off)
[wt1_15, wt2_15] = request.security(syminfo.tickerid, "15",  wt_calc(), lookahead=barmerge.lookahead_off)

p5m1 = wt1
p15m1 = wt1_15
p1h1 = wt1_1h

var bool longReadyBuy = false

longPl = ta.pivotlow(longPivotLength, longPivotLength)

var float longPrevSwingLow = na
var float longLastSwingLow = na
var int longLastSwingLowBarIndex = na
var bool longIsHL = false

if not na(longPl)
    longIsHL := na(longPrevSwingLow) ? false : longPl >= longPrevSwingLow
    longLastSwingLow := longPl
    longLastSwingLowBarIndex := bar_index - longPivotLength
    longPrevSwingLow := longPl
else
    longIsHL := false

longReadyBuyCondition = p5m1 <= longReadyBuyThreshold and p15m1 <= longReadyBuyThreshold and p1h1 < longP1h1UpperLimit

if not longReadyBuy and longReadyBuyCondition
    longReadyBuy := true

if longReadyBuy and strategy.position_size == 0 and p1h1 > longThresholdLevel
    longReadyBuy := false

var bool longCondition3 = false

longCheckFullCondition(offset) =>
    p5m1_val = p5m1[offset]
    p15m1_val = p15m1[offset]
    p1h1_val = p1h1[offset]
    longP5UpperLimit >= p5m1_val and p5m1_val > p15m1_val and p15m1_val > p1h1_val

longCheckCondition2(offset) =>
    p15m1_val = p15m1[offset]
    p1h1_val = p1h1[offset]
    longP15LowerLimit > p15m1_val and p15m1_val > p1h1_val

longCheckSimpleCondition(offset) =>
    p5m1_val = p5m1[offset]
    p15m1_val = p15m1[offset]
    p5m1_val > p15m1_val

longCheckCrossCondition(offset) =>
    p15m1_val = p15m1[offset]
    p1h1_val = p1h1[offset]
    p15m1_val > p1h1_val

longCurrentFullSatisfy = longCheckFullCondition(0)

longCurrentCondition2Satisfy = longCheckCondition2(0)

longCurrentSimpleSatisfy = longCheckSimpleCondition(0)
longPrev1NotSimpleSatisfy = not longCheckSimpleCondition(1)
longCondition3A = longCurrentSimpleSatisfy and longPrev1NotSimpleSatisfy

longCurrentCrossSatisfy = longCheckCrossCondition(0)
longPrev1NotCrossSatisfy = not longCheckCrossCondition(1)
longCondition3B = longCurrentCrossSatisfy and longPrev1NotCrossSatisfy

longCondition3 := longCondition3A or longCondition3B

avgHeightLength = math.max(longAvgHeightLength, shortAvgHeightLength)
var float avgCandleHeight = na

if bar_index >= avgHeightLength - 1
    sumHeight = 0.0
    for i = 0 to avgHeightLength - 1
        sumHeight += high[i] - low[i]
    avgCandleHeight := sumHeight / avgHeightLength
else
    if bar_index >= 0
        sumHeight = 0.0
        for i = 0 to bar_index
            sumHeight += high[i] - low[i]
        avgCandleHeight := sumHeight / (bar_index + 1)
    else
        avgCandleHeight := na

detectLongBullishFVG(offset, avgCandleHeight, gapMultiplier) =>
    htfHigh1_5m = high[offset]
    htfLow1_5m = low[offset]
    htfHigh3_5m = high[2 + offset]
    htfLow3_5m = low[2 + offset]
    isFvgPattern = htfHigh3_5m < htfLow1_5m
    fvgGap = htfLow1_5m - htfHigh3_5m
    minGapRequired = not na(avgCandleHeight) and avgCandleHeight > 0 ? avgCandleHeight / gapMultiplier : 0
    isGapValid = fvgGap > minGapRequired
    fvgMinPrice = htfLow1_5m
    isValid = isFvgPattern and isGapValid
    [isValid, fvgMinPrice]

var bool longFvgWindowActive = false
var int longFvgWindowStart = na  
var int longFvgLookbackStart = na  

longCondition123Met = enableLong and longReadyBuy and strategy.position_size == 0 and longCurrentFullSatisfy and longCurrentCondition2Satisfy and longCondition3

if longCondition123Met and not longFvgWindowActive
    longFvgWindowActive := true
    longFvgWindowStart := bar_index
    longFvgLookbackStart := bar_index - longFvgLookbackBars
else if longFvgWindowActive
    if bar_index - longFvgWindowStart > longFvgWaitBars or not longReadyBuy
        longFvgWindowActive := false
        longFvgWindowStart := na
        longFvgLookbackStart := na

longFvgConfirmed = false
if longFvgWindowActive and not na(longFvgLookbackStart) and longFvgLookbackStart >= 3
    maxOffset = bar_index - longFvgLookbackStart
    maxCheckOffset = math.min(maxOffset, 20)
    for offset = 0 to math.max(0, maxCheckOffset)
        [isValid, fvgMinPrice] = detectLongBullishFVG(offset, avgCandleHeight, longFvgGapMultiplier)
        priceCheckPassed = not longEnableFvgPriceCheck or close > fvgMinPrice
        if isValid and priceCheckPassed
            longFvgConfirmed := true
            break

longCondition = enableLong and longReadyBuy and strategy.position_size == 0 and longFvgConfirmed

var float longEntryPrice = na
var float longCurrentStopLoss = na
var float longInitialTakeProfit = na
var float longEntryBarLow = na
var bool longMovedToBreakeven = false

if longCondition
    longEntryPrice := close
    longLowest3Bars = ta.lowest(low, 3)  
    longBaseStopLoss = not na(longLastSwingLow) and longLastSwingLow < close ? longLastSwingLow : longLowest3Bars
    longCalculatedStopLoss = not na(avgCandleHeight) ? longBaseStopLoss - avgCandleHeight : longBaseStopLoss
    longCurrentStopLoss := na(longCalculatedStopLoss) or longCalculatedStopLoss <= 0 ? longLowest3Bars : longCalculatedStopLoss
    longInitialTakeProfit := longEntryPrice + (longEntryPrice - longCurrentStopLoss) * longRiskRewardRatio
    longEntryBarLow := low
    longMovedToBreakeven := false
    longFvgWindowActive := false
    longFvgWindowStart := na
    longFvgLookbackStart := na
    longQtyForEntry = enableRiskBasedSizing ? calcRiskBasedQty(longEntryPrice, longCurrentStopLoss) : na
    strategy.entry("Long", strategy.long, qty=enableRiskBasedSizing and not na(longQtyForEntry) ? longQtyForEntry : na, comment="止损价: " + str.tostring(longCurrentStopLoss, "#.##"))

if strategy.position_size > 0
    if not longMovedToBreakeven and p5m1 >= longPartialCloseLevel and close > longEntryPrice * longBreakevenFactor
        longCurrentStopLoss := longEntryPrice * longBreakevenFactor
        longMovedToBreakeven := true

longStopLossTriggered = strategy.position_size > 0 and not na(longCurrentStopLoss) and close <= longCurrentStopLoss

longProfitTarget1 = strategy.position_size > 0 and not longStopLossTriggered and close >= longInitialTakeProfit

longProfitTarget2 = longEnableProfitTarget2 and strategy.position_size > 0 and not longStopLossTriggered and p5m1 > longThresholdLevel and p15m1 > longThresholdLevel

if longProfitTarget1 or longProfitTarget2
    strategy.close("Long", comment="止盈")
    longEntryPrice := na
    longCurrentStopLoss := na
    longInitialTakeProfit := na
    longEntryBarLow := na
    longMovedToBreakeven := false
    longFvgWindowActive := false
    longFvgWindowStart := na
    longFvgLookbackStart := na

if strategy.position_size > 0
    strategy.exit("Long Exit", "Long", stop=longCurrentStopLoss)

var bool shortReadySell = false

shortPh = ta.pivothigh(shortPivotLength, shortPivotLength)

var float shortPrevSwingHigh = na
var float shortLastSwingHigh = na
var int shortLastSwingHighBarIndex = na
var bool shortIsHH = false

if not na(shortPh)
    shortIsHH := na(shortPrevSwingHigh) ? false : shortPh > shortPrevSwingHigh
    shortLastSwingHigh := shortPh
    shortLastSwingHighBarIndex := bar_index - shortPivotLength
    shortPrevSwingHigh := shortPh
else
    shortIsHH := false

shortReadySellCondition = p5m1 >= shortReadySellThreshold and p15m1 >= shortReadySellThreshold and p1h1 > shortP1h1LowerLimit

if not shortReadySell and shortReadySellCondition
    shortReadySell := true

if shortReadySell and strategy.position_size == 0 and p1h1 < shortThresholdLevel
    shortReadySell := false

var bool shortCondition3 = false

shortCheckFullCondition(offset) =>
    p5m1_val = p5m1[offset]
    p15m1_val = p15m1[offset]
    p1h1_val = p1h1[offset]
    shortP5LowerLimit < p5m1_val and p5m1_val < p15m1_val and p15m1_val < p1h1_val

shortCheckCondition2(offset) =>
    p15m1_val = p15m1[offset]
    p1h1_val = p1h1[offset]
    shortP15UpperLimit < p15m1_val and p15m1_val < p1h1_val

shortCheckSimpleCondition(offset) =>
    p5m1_val = p5m1[offset]
    p15m1_val = p15m1[offset]
    p5m1_val < p15m1_val

shortCheckCrossCondition(offset) =>
    p15m1_val = p15m1[offset]
    p1h1_val = p1h1[offset]
    p15m1_val < p1h1_val

shortCurrentFullSatisfy = shortCheckFullCondition(0)

shortCurrentCondition2Satisfy = shortCheckCondition2(0)

shortCurrentSimpleSatisfy = shortCheckSimpleCondition(0)
shortPrev1NotSimpleSatisfy = not shortCheckSimpleCondition(1)
shortCondition3A = shortCurrentSimpleSatisfy and shortPrev1NotSimpleSatisfy

shortCurrentCrossSatisfy = shortCheckCrossCondition(0)
shortPrev1NotCrossSatisfy = not shortCheckCrossCondition(1)
shortCondition3B = shortCurrentCrossSatisfy and shortPrev1NotCrossSatisfy

shortCondition3 := shortCondition3A or shortCondition3B

detectShortBearishFVG(offset, avgCandleHeight, gapMultiplier) =>
    htfHigh1_5m = high[offset]
    htfLow1_5m = low[offset]
    htfHigh3_5m = high[2 + offset]
    htfLow3_5m = low[2 + offset]
    isFvgPattern = htfLow3_5m > htfHigh1_5m
    fvgGap = htfLow3_5m - htfHigh1_5m
    minGapRequired = not na(avgCandleHeight) and avgCandleHeight > 0 ? avgCandleHeight / gapMultiplier : 0
    isGapValid = fvgGap > minGapRequired
    fvgMaxPrice = htfHigh1_5m
    isValid = isFvgPattern and isGapValid
    [isValid, fvgMaxPrice]

var bool shortFvgWindowActive = false
var int shortFvgWindowStart = na  
var int shortFvgLookbackStart = na  

shortCondition123Met = enableShort and shortReadySell and strategy.position_size == 0 and shortCurrentFullSatisfy and shortCurrentCondition2Satisfy and shortCondition3

if shortCondition123Met and not shortFvgWindowActive
    shortFvgWindowActive := true
    shortFvgWindowStart := bar_index
    shortFvgLookbackStart := bar_index - shortFvgLookbackBars
else if shortFvgWindowActive
    if bar_index - shortFvgWindowStart > shortFvgWaitBars or not shortReadySell
        shortFvgWindowActive := false
        shortFvgWindowStart := na
        shortFvgLookbackStart := na

shortFvgConfirmed = false
if shortFvgWindowActive and not na(shortFvgLookbackStart) and shortFvgLookbackStart >= 3
    maxOffset = bar_index - shortFvgLookbackStart
    maxCheckOffset = math.min(maxOffset, 20)
    for offset = 0 to math.max(0, maxCheckOffset)
        [isValid, fvgMaxPrice] = detectShortBearishFVG(offset, avgCandleHeight, shortFvgGapMultiplier)
        priceCheckPassed = not shortEnableFvgPriceCheck or close < fvgMaxPrice
        if isValid and priceCheckPassed
            shortFvgConfirmed := true
            break

shortCondition = enableShort and shortReadySell and strategy.position_size == 0 and shortFvgConfirmed

var float shortEntryPrice = na
var float shortCurrentStopLoss = na
var float shortInitialTakeProfit = na
var float shortEntryBarHigh = na
var bool shortMovedToBreakeven = false

if shortCondition
    shortEntryPrice := close
    shortHighest3Bars = ta.highest(high, 3)  
    shortBaseStopLoss = not na(shortLastSwingHigh) and shortLastSwingHigh > close ? shortLastSwingHigh : shortHighest3Bars
    shortCalculatedStopLoss = not na(avgCandleHeight) ? shortBaseStopLoss + avgCandleHeight : shortBaseStopLoss
    shortCurrentStopLoss := na(shortCalculatedStopLoss) or shortCalculatedStopLoss <= 0 ? shortHighest3Bars : shortCalculatedStopLoss
    shortInitialTakeProfit := shortEntryPrice - (shortCurrentStopLoss - shortEntryPrice) * shortRiskRewardRatio
    shortEntryBarHigh := high
    shortMovedToBreakeven := false
    shortFvgWindowActive := false
    shortFvgWindowStart := na
    shortFvgLookbackStart := na
    shortQtyForEntry = enableRiskBasedSizing ? calcRiskBasedQty(shortEntryPrice, shortCurrentStopLoss) : na
    strategy.entry("Short", strategy.short, qty=enableRiskBasedSizing and not na(shortQtyForEntry) ? shortQtyForEntry : na, comment="止损价: " + str.tostring(shortCurrentStopLoss, "#.##"))

if strategy.position_size < 0
    if not shortMovedToBreakeven and p5m1 <= shortPartialCloseLevel and close < shortEntryPrice * shortBreakevenFactor
        shortCurrentStopLoss := shortEntryPrice * shortBreakevenFactor
        shortMovedToBreakeven := true

shortStopLossTriggered = strategy.position_size < 0 and not na(shortCurrentStopLoss) and close >= shortCurrentStopLoss
if shortStopLossTriggered
    strategy.close("Short", comment="止损")
    shortEntryPrice := na
    shortCurrentStopLoss := na
    shortInitialTakeProfit := na
    shortEntryBarHigh := na
    shortMovedToBreakeven := false
    shortFvgWindowActive := false
    shortFvgWindowStart := na
    shortFvgLookbackStart := na

shortProfitTarget1 = strategy.position_size < 0 and not shortStopLossTriggered and close <= shortInitialTakeProfit

shortProfitTarget2 = shortEnableProfitTarget2 and strategy.position_size < 0 and not shortStopLossTriggered and p5m1 < shortThresholdLevel and p15m1 < shortThresholdLevel

if shortProfitTarget1 or shortProfitTarget2
    strategy.close("Short", comment="止盈")
    shortEntryPrice := na
    shortCurrentStopLoss := na
    shortInitialTakeProfit := na
    shortEntryBarHigh := na
    shortMovedToBreakeven := false
    shortFvgWindowActive := false
    shortFvgWindowStart := na
    shortFvgLookbackStart := na

if strategy.position_size < 0
    strategy.exit("Short Exit", "Short", stop=shortCurrentStopLoss)

plot(wt1, color=color.new(color.aqua, 0), title="WT1 (5m)", linewidth=2)

plot(showMTF and show4H ? wt1_4h : na, color=color.new(color.red, 0),  title="WT1 (4H)", linewidth=2)

plot(showMTF and show1H ? wt1_1h : na, color=color.new(color.orange, 0),  title="WT1 (1H)", linewidth=2)

plot(showMTF and show15 ? wt1_15 : na, color=color.new(color.yellow, 0),  title="WT1 (15m)", linewidth=2)

plot(0, color=color.gray, title="Zero Line")
plot(obLevel1, color=color.red, title="OB +60")
plot(midLevelHigh, color=color.red, title="看空阈值 +50")
plot(midLevelLow, color=color.green, title="看多阈值 -50")
plot(osLevel1, color=color.green, title="OS -60")
