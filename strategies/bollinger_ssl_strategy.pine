//@version=5
strategy("布林带+SSL策略", overlay=true, max_lines_count=500, max_labels_count=500, default_qty_type=strategy.percent_of_equity, default_qty_value=100)

// ==================== 输入参数 ====================

// SSL参数
ssl_period = input.int(200, "SSL周期", minval=1, group="SSL设置")
ssl_wma_length = input.int(200, "SSL WMA长度", minval=1, group="SSL设置")
show_ssl = input.bool(true, "显示SSL通道", group="SSL设置")

// 布林带参数
showMyboll = input.bool(true, '显示布林带', group="布林带设置")
myboll_length = input.int(20, minval=1, title="布林带长度", group="布林带设置")
myboll_type = input.string("SMA", "布林带MA类型", options = ["SMA", "EMA", "SMMA (RMA)", "WMA", "VWMA"], group="布林带设置")
myboll_src = input(close, title="数据源", group="布林带设置")
myboll_mult = input.float(2.0, minval=0.001, maxval=50, title="标准差倍数", group="布林带设置")

// 策略参数
initial_position_usd = input.float(100.0, "初始仓位(美元)", minval=1.0, step=1.0, group="策略设置")

// 风控设置
enable_risk_control = input.bool(false, "开启风控模式", group="风控设置")
max_risk_percent = input.float(1.0, "风控最大比例(%)", minval=0.1, maxval=10.0, step=0.1, group="风控设置")

// ==================== 布林带计算 ====================

// MA计算函数
ma(source, length, _type) =>
    switch _type
        "SMA" => ta.sma(source, length)
        "EMA" => ta.ema(source, length)
        "SMMA (RMA)" => ta.rma(source, length)
        "WMA" => ta.wma(source, length)
        "VWMA" => ta.vwma(source, length)
        => ta.sma(source, length)

// 1号布林带（原始周期）
myboll_basis = ma(myboll_src, myboll_length, myboll_type)
myboll_dev = myboll_mult * ta.dev(myboll_src, myboll_length)
myboll_upper = myboll_basis + myboll_dev
myboll_lower = myboll_basis - myboll_dev

// 2号布林带（3倍周期）
myboll_basis2 = ma(myboll_src, myboll_length * 3, myboll_type)
myboll_dev2 = myboll_mult * ta.dev(myboll_src, myboll_length * 3)
myboll_upper2 = myboll_basis2 + myboll_dev2
myboll_lower2 = myboll_basis2 - myboll_dev2

// 3号布林带（12倍周期）
myboll_basis3 = ma(myboll_src, myboll_length * 12, myboll_type)
myboll_dev3 = myboll_mult * ta.dev(myboll_src, myboll_length * 12)
myboll_upper3 = myboll_basis3 + myboll_dev3
myboll_lower3 = myboll_basis3 - myboll_dev3

// 绘制布林带
plot(showMyboll ? myboll_basis : na, "1号布林中轨", color=#089981, linewidth=2)
plot(showMyboll ? myboll_upper : na, "1号布林上轨", color=#089981)
plot(showMyboll ? myboll_lower : na, "1号布林下轨", color=#089981)

plot(showMyboll ? myboll_basis2 : na, "2号布林中轨", color=#2962FF, linewidth=2)
plot(showMyboll ? myboll_upper2 : na, "2号布林上轨", color=#2962FF)
plot(showMyboll ? myboll_lower2 : na, "2号布林下轨", color=#2962FF)

plot(showMyboll ? myboll_basis3 : na, "3号布林中轨", color=#F23645, linewidth=2)
plot(showMyboll ? myboll_upper3 : na, "3号布林上轨", color=#F23645)
plot(showMyboll ? myboll_lower3 : na, "3号布林下轨", color=#F23645)

// ==================== SSL指标计算 ====================

// SSL指标计算函数
ssl_calc(period, wma_len) =>
    smaHigh = ta.wma(high, wma_len)
    smaLow = ta.wma(low, wma_len)
    
    var float Hlv = na
    Hlv := close > smaHigh ? 1 : close < smaLow ? -1 : Hlv[1]
    
    sslDown = Hlv < 0 ? smaHigh : smaLow
    sslUp = Hlv < 0 ? smaLow : smaHigh
    
    [sslUp, sslDown, Hlv]

// 当前时间框架SSL
[current_ssl_up, current_ssl_down, current_hlv] = ssl_calc(ssl_period, ssl_wma_length)

// 绘制SSL通道
p1 = plot(show_ssl ? current_ssl_down : na, linewidth=1, color=color.new(color.green, 80), title="SSL下轨")
p2 = plot(show_ssl ? current_ssl_up : na, linewidth=1, color=color.new(color.green, 80), title="SSL上轨")
fill(p1, p2, color = current_hlv > 0 ? color.new(color.green, 80) : color.new(color.red, 80), title="SSL填充")

// ==================== 策略变量 ====================

var float long_stop_loss_level = na
var float long_entry_price = na
var float long_initial_stop = na
var int long_entry_bar = 0
var bool long_breakeven_set = false
var bool long_take_profit_by_ratio = false
var bool long_take_profit_by_boll = false

// ==================== 开仓条件判断 ====================

// 准备做多条件
prepare_long_condition = current_hlv > 0 and myboll_lower > myboll_basis3 and myboll_basis2 > myboll_basis3 and myboll_lower2 > myboll_lower3 and myboll_lower > myboll_lower3

// 准备做多条件失效判定
var bool long_prepared = false
if prepare_long_condition and not long_prepared
    long_prepared := true
else if myboll_basis2 < myboll_basis3 and long_prepared  // 2号布林带中轨小于3号布林带中轨时失效
    long_prepared := false

// 计算K线实体和上下引线
body = math.abs(close - open)
upper_shadow = high - math.max(open, close)
lower_shadow = math.min(open, close) - low
is_bullish_candle = close > open  // 上涨K线
upper_shadow_small = body > 0 ? (upper_shadow / body) < 0.333 : false  // 上引线小于实体三分之一

// 立即开单做多条件
long_condition = long_prepared and high > myboll_upper and high > myboll_upper2 and high > myboll_basis3  and low < myboll_upper and low < myboll_upper3 and low > myboll_basis3 and is_bullish_candle and upper_shadow_small and close > myboll_basis and close > myboll_basis2 and close > myboll_basis3 and myboll_basis > myboll_basis3 and myboll_basis2 > myboll_basis3

// ==================== 止损止盈管理 ====================

// 开仓时设置初始止损位（使用3号布林带中轨）
if long_condition and strategy.position_size == 0
    long_stop_loss_level := myboll_basis3
    long_initial_stop := myboll_basis3  // 保存初始止损位
    long_entry_bar := bar_index
    long_breakeven_set := false

// 多单移动止损：盈利达到1:2时设置保本止损
if strategy.position_size > 0 and not na(long_entry_price) and not long_breakeven_set
    profit_points = close - long_entry_price
    risk_points = long_entry_price - long_initial_stop
    if profit_points >= risk_points * 2 and risk_points > 0  // 达到1:2盈亏比
        long_stop_loss_level := long_entry_price  // 保本止损
        long_breakeven_set := true

// ==================== 止损止盈条件 ====================

// 多单止损：价格收盘价小于止损位
long_stop_loss = close < long_stop_loss_level

// 多单止盈：使用1:3盈亏比或2号布林线中轨小于3号布林线中轨
long_take_profit_by_ratio_level = not na(long_entry_price) and not na(long_initial_stop) ? long_entry_price + (long_entry_price - long_initial_stop) * 3 : na
long_take_profit_by_ratio := high >= long_take_profit_by_ratio_level
long_take_profit_by_boll := myboll_basis2 < myboll_basis3

// 多单总止盈条件
long_take_profit = long_take_profit_by_ratio or long_take_profit_by_boll

// 绘制止损止盈线
plot(strategy.position_size > 0 ? long_stop_loss_level : na, "多单止损线", color=color.red, linewidth=2, style=plot.style_linebr)
plot(strategy.position_size > 0 ? long_take_profit_by_ratio_level : na, "多单止盈线(1:3)", color=color.green, linewidth=2, style=plot.style_linebr)

// ==================== 风控函数 ====================

calculate_position_size(entry_price, stop_loss_price) =>
    position_value = initial_position_usd  // 默认值
    
    if enable_risk_control
        // 计算止损百分比
        stop_loss_percent = math.abs(entry_price - stop_loss_price) / entry_price
        
        // 获取当前账户总价值
        current_equity = strategy.equity
        base_capital = current_equity < 100 ? 100 : current_equity
        
        // 计算最大允许亏损金额
        max_loss_amount = base_capital * (max_risk_percent / 100)
        
        // 计算下单金额
        if stop_loss_percent > 0
            position_value := max_loss_amount / stop_loss_percent
            position_value := math.max(position_value, 100)
    
    position_value

// ==================== 策略执行 ====================

// 开多单
if long_condition and strategy.position_size == 0
    position_value = calculate_position_size(close, myboll_basis3)
    position_qty = position_value / close
    strategy.entry("Long", strategy.long, qty=position_qty)
    long_entry_price := close
    long_breakeven_set := false

// 多单出场
if strategy.position_size > 0
    if long_stop_loss
        strategy.close("Long", comment="多单止损")
        long_entry_price := na
        long_stop_loss_level := na
        long_initial_stop := na
        long_entry_bar := 0
        long_breakeven_set := false
        long_prepared := false  // 重置准备做多条件
    else if long_take_profit
        strategy.close("Long", comment="多单止盈")
        long_entry_price := na
        long_stop_loss_level := na
        long_initial_stop := na
        long_entry_bar := 0
        long_breakeven_set := false
        long_prepared := false  // 重置准备做多条件

// ==================== 做空条件判断 ====================

// 准备做空条件（与做多相反）
prepare_short_condition = current_hlv < 0 and myboll_upper < myboll_basis3 and myboll_basis2 < myboll_basis3 and myboll_upper2 < myboll_upper3 and myboll_upper < myboll_upper3

// 准备做空条件失效判定
var bool short_prepared = false
if prepare_short_condition and not short_prepared
    short_prepared := true
else if myboll_basis2 > myboll_basis3 and short_prepared  // 2号布林带中轨大于3号布林带中轨时失效
    short_prepared := false

// 计算K线实体和上下引线（用于做空）
is_bearish_candle = close < open  // 下跌K线
lower_shadow_small = body > 0 ? (lower_shadow / body) < 0.333 : false  // 下引线小于实体三分之一

// 立即开单做空条件（与做多相反）
short_condition = short_prepared and low < myboll_lower and low < myboll_lower2 and low < myboll_basis3 and high > myboll_lower and high > myboll_lower3 and high < myboll_basis3 and is_bearish_candle and lower_shadow_small and close < myboll_basis and close < myboll_basis2 and close < myboll_basis3 and myboll_basis < myboll_basis3 and myboll_basis2 < myboll_basis3

// ==================== 做空止损止盈管理 ====================

// 做空止损止盈位变量
var float short_stop_loss_level = na
var float short_entry_price = na
var float short_initial_stop = na
var int short_entry_bar = 0
var bool short_breakeven_set = false
var bool short_take_profit_by_ratio = false
var bool short_take_profit_by_boll = false

// 开仓时设置初始止损位（使用3号布林带中轨）
if short_condition and strategy.position_size == 0
    short_stop_loss_level := myboll_basis3
    short_initial_stop := myboll_basis3  // 保存初始止损位
    short_entry_bar := bar_index
    short_breakeven_set := false

// 空单移动止损：盈利达到1:2时设置保本止损
if strategy.position_size < 0 and not na(short_entry_price) and not short_breakeven_set
    profit_points = short_entry_price - close
    risk_points = short_initial_stop - short_entry_price
    if profit_points >= risk_points * 2 and risk_points > 0  // 达到1:2盈亏比
        short_stop_loss_level := short_entry_price  // 保本止损
        short_breakeven_set := true

// ==================== 做空止损止盈条件 ====================

// 空单止损：价格收盘价大于止损位
short_stop_loss = close > short_stop_loss_level

// 空单止盈：使用1:3盈亏比或2号布林线中轨大于3号布林线中轨
short_take_profit_by_ratio_level = not na(short_entry_price) and not na(short_initial_stop) ? short_entry_price - (short_initial_stop - short_entry_price) * 3 : na
short_take_profit_by_ratio := low <= short_take_profit_by_ratio_level
short_take_profit_by_boll := myboll_basis2 > myboll_basis3

// 空单总止盈条件
short_take_profit = short_take_profit_by_ratio or short_take_profit_by_boll

// 绘制做空止损止盈线
plot(strategy.position_size < 0 ? short_stop_loss_level : na, "空单止损线", color=color.red, linewidth=2, style=plot.style_linebr)
plot(strategy.position_size < 0 ? short_take_profit_by_ratio_level : na, "空单止盈线(1:3)", color=color.green, linewidth=2, style=plot.style_linebr)

// ==================== 做空策略执行 ====================

// 开空单
if short_condition and strategy.position_size == 0
    position_value = calculate_position_size(close, myboll_basis3)
    position_qty = position_value / close
    strategy.entry("Short", strategy.short, qty=position_qty)
    short_entry_price := close
    short_breakeven_set := false

// 空单出场
if strategy.position_size < 0
    if short_stop_loss
        strategy.close("Short", comment="空单止损")
        short_entry_price := na
        short_stop_loss_level := na
        short_initial_stop := na
        short_entry_bar := 0
        short_breakeven_set := false
        short_prepared := false  // 重置准备做空条件
    else if short_take_profit
        strategy.close("Short", comment="空单止盈")
        short_entry_price := na
        short_stop_loss_level := na
        short_initial_stop := na
        short_entry_bar := 0
        short_breakeven_set := false
        short_prepared := false  // 重置准备做空条件
