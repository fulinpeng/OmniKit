//@version=5
indicator("Squeeze Box [DW] (v5 strict v2 semantics + HULLMA)", overlay=true, max_lines_count=500, max_labels_count=500)

// Inputs
src    = input.source(hlc3, "Source")
per    = input.int(21, "Sampling Period", minval=1)
matype = input.string("EMA", "MA Type", options=["EMA","SMA","HULLMA"])
ndev   = input.float(2, "Number of Deviations for Squeeze Calculation", minval=1)
sr     = input.float(50, "Relative Squeeze % Threshold", minval=0, maxval=100, step=0.01)

// v2 HullMA semantics
halfPer  = math.max(1, int(per / 2))
sqrtPerR = math.max(1, int(math.round(math.sqrt(per))))

// MAs
ema_  = ta.ema(src, per)
sma_  = ta.sma(src, per)
hull_ = ta.wma(2.0 * ta.wma(src, halfPer) - ta.wma(src, per), sqrtPerR)

ma = switch matype
    "EMA"    => ema_
    "SMA"    => sma_
    "HULLMA" => hull_
    => ema_

// Bollinger Bands
dev = ta.stdev(src, per) * ndev
bu  = ma + dev
bd  = ma - dev
bw  = bu - bd

// Squeeze %
buh  = ta.highest(bu, per)
bdl  = ta.lowest(bd, per)
brng = buh - bdl
sqp  = 100.0 * bw / brng

// ★ v2 语义：na 条件走 else => 永远 true/false
sqz = (sqp < sr) ? true : false

// Squeeze Box
boxh = sqz ? ta.highest(src, per) : src
boxl = sqz ? ta.lowest(src, per)  : src

// ★ 关键：手写 v2 valuewhen(sqz, box?, 1)
// v2 的 valuewhen：每根 sqz=true 都算一次触发；occ=1 取“上一次触发”的值
var float last_boxh = na
var float prev_boxh = na
var float last_boxl = na
var float prev_boxl = na

if sqz
    prev_boxh := last_boxh
    last_boxh := boxh
    prev_boxl := last_boxl
    last_boxl := boxl

bh = prev_boxh
bl = prev_boxl

// Colors
boxcolor = src > bh ? color.lime : src < bl ? color.red : color.orange
macolor  = ma > ma[1] ? color.lime : ma < ma[1] ? color.red : color.orange

barCol =
     (src > bh and src > src[1]) ? color.lime   :
     (src > bh and src < src[1]) ? color.green  :
     (src < bl and src < src[1]) ? color.red    :
     (src < bl and src > src[1]) ? color.maroon :
     color.orange

// Plots
bhplot = plot(bh, color=boxcolor, title="Box High")
blplot = plot(bl, color=boxcolor, title="Box Low")
plot(ma, color=macolor, linewidth=2, title="MA")
fill(bhplot, blplot, color=color.new(boxcolor, 70), title="Box Fill")
barcolor(barCol, title="Bar Color")
